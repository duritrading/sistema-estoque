{
  "name": "sistema-estoque",
  "version": "2.0.0",
  "description": "Sistema de Estoque OF Distribuidora",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "concurrently \"npm run dev:js\" \"npm run dev:css\"",
    "dev:js": "nodemon src/app.js",
    "dev:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/styles.css --watch",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/styles.css --minify"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.17.3",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}