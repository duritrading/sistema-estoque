<!-- views/dre.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DRE | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <style>
    .dre-table {
      font-size: 13px;
      border-collapse: collapse;
    }
    .dre-table th,
    .dre-table td {
      padding: 8px 12px;
      border: 1px solid #e2e8f0;
      white-space: nowrap;
    }
    .dre-table th {
      background: #f8fafc;
      font-weight: 600;
    }
    .dre-table th:first-child,
    .dre-table td:first-child {
      min-width: 280px;
      white-space: normal;
      position: sticky;
      left: 0;
      z-index: 1;
    }
    
    /* GRUPO: Negrito sem fundo - tÃ­tulo de seÃ§ÃĢo */
    .dre-grupo td {
      font-weight: 700;
      background-color: #fff !important;
      color: #0f172a;
      border-top: 2px solid #cbd5e1;
    }
    .dre-grupo td:first-child {
      background-color: #fff !important;
    }
    
    /* ITEM: Normal, indentado */
    .dre-item td {
      background-color: #fff;
      color: #475569;
    }
    .dre-item td:first-child {
      padding-left: 28px;
      background-color: #fff !important;
    }
    
    /* SUBTOTAL: Negrito + fundo cinza claro */
    .dre-subtotal td {
      font-weight: 700;
      background-color: #e2e8f0 !important;
      color: #0f172a;
    }
    .dre-subtotal td:first-child {
      background-color: #e2e8f0 !important;
    }
    
    /* TOTAL: Negrito + fundo cinza escuro */
    .dre-total td {
      font-weight: 700;
      background-color: #cbd5e1 !important;
      color: #0f172a;
    }
    .dre-total td:first-child {
      background-color: #cbd5e1 !important;
    }
    
    /* TOTAL FINAL: Negrito + fundo verde */
    .dre-total-final td {
      font-weight: 700;
      background-color: #bbf7d0 !important;
      color: #166534;
      border-top: 2px solid #166534;
      border-bottom: 2px solid #166534;
    }
    .dre-total-final td:first-child {
      background-color: #bbf7d0 !important;
    }
    
    /* Valores negativos em vermelho */
    .valor-negativo {
      color: #dc2626 !important;
    }
    
    /* Coluna Total Ano */
    .col-total-ano {
      background-color: #f1f5f9 !important;
      font-weight: 600;
    }
  </style>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'dre' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container" style="max-width: 1600px;">
      
      <!-- Page Header -->
      <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-secondary-900">DRE - Demonstrativo de Resultado</h1>
            <p class="mt-1 text-secondary-500">Visão gerencial do exercício <%= ano %></p>
          </div>
          
          <!-- Filtro de Ano -->
          <form method="GET" class="flex items-center gap-3">
            <label class="text-sm text-secondary-600">Ano:</label>
            <select name="ano" class="form-select w-28" onchange="this.form.submit()">
              <% for (var a = new Date().getFullYear(); a >= 2020; a--) { %>
                <option value="<%= a %>" <%= ano == a ? 'selected' : '' %>><%= a %></option>
              <% } %>
            </select>
            <button type="button" onclick="window.print()" class="btn btn-secondary">
              <i data-lucide="printer" class="w-4 h-4 mr-2"></i>
              Imprimir
            </button>
          </form>
        </div>
      </div>

      <!-- DRE Table -->
      <div class="card">
        <div class="card-header flex items-center justify-between">
          <h2 class="text-lg font-semibold text-secondary-900 flex items-center gap-2">
            <i data-lucide="bar-chart-3" class="w-5 h-5 text-primary-600"></i>
            DRE Gerencial - <%= ano %>
          </h2>
          <span class="text-sm text-secondary-500">Valores em R$</span>
        </div>
        
        <div class="overflow-x-auto">
          <table class="table dre-table w-full">
            <thead>
              <tr>
                <th class="text-left">Categoria</th>
                <% meses.forEach(function(mes) { %>
                  <th class="text-right"><%= mes %></th>
                <% }); %>
                <th class="text-right col-total-ano">Total Ano</th>
              </tr>
            </thead>
            <tbody>
              <% estrutura.forEach(function(linha) { 
                // Pega valores calculados para a linha atual
                var valores = resultados[linha.id];
                var temValores = valores !== null;
                
                // Calcular total anual
                var totalAnual = 0;
                if (temValores) {
                  totalAnual = valores.reduce(function(a, b) { return a + b; }, 0);
                }
                
                // Definir classe CSS baseada no tipo
                var cssClass = '';
                if (linha.tipo === 'grupo') cssClass = 'dre-grupo';
                else if (linha.tipo === 'item') cssClass = 'dre-item';
                else if (linha.tipo === 'subtotal') cssClass = 'dre-subtotal';
                else if (linha.tipo === 'total') cssClass = 'dre-total';
                else if (linha.tipo === 'total-final') cssClass = 'dre-total-final';
              %>
                <tr class="<%= cssClass %>">
                  <td><%= linha.label %></td>

                  <% if (temValores) { %>
                    <% valores.forEach(function(valor) { %>
                      <td class="text-right <%= valor < 0 ? 'valor-negativo' : '' %>">
                        <% if (Math.abs(valor) >= 0.01) { %>
                          <%= valor.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                        <% } else { %>
                          <span class="text-secondary-300">-</span>
                        <% } %>
                      </td>
                    <% }); %>
                    <td class="text-right col-total-ano <%= totalAnual < 0 ? 'valor-negativo' : '' %>">
                      <% if (Math.abs(totalAnual) >= 0.01) { %>
                        <%= totalAnual.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                      <% } else { %>
                        <span class="text-secondary-300">-</span>
                      <% } %>
                    </td>
                  <% } else { %>
                    <!-- Grupo: cÃĐlulas vazias -->
                    <% for (var i = 0; i < 13; i++) { %>
                      <td></td>
                    <% } %>
                  <% } %>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Legenda -->
      <div class="mt-6 flex flex-wrap gap-4 text-sm">
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded border-2 border-secondary-300 bg-white"></div>
          <span class="text-secondary-600">Grupo (tí­tulo)</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded bg-[#e2e8f0] border border-secondary-300"></div>
          <span class="text-secondary-600">Subtotal do grupo</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded bg-[#cbd5e1] border border-secondary-300"></div>
          <span class="text-secondary-600">Total acumulado</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded bg-[#bbf7d0] border border-green-400"></div>
          <span class="text-secondary-600">Resultado Final</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded bg-white border border-red-400 flex items-center justify-center text-red-600 text-xs font-bold">-</div>
          <span class="text-secondary-600">Valor Negativo</span>
        </div>
      </div>

    </main>
  </div>

  <!-- Print Styles -->
  <style>
    @media print {
      /* Esconder TUDO exceto a tabela */
      body * {
        visibility: hidden;
      }
      
      /* Mostrar apenas o card da DRE e seus filhos */
      .card, .card * {
        visibility: visible;
      }
      
      /* Esconder header do card (tÃ­tulo e botÃĩes) */
      .card-header {
        display: none !important;
      }
      
      /* Posicionar o card no topo da pÃĄgina */
      .card {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        box-shadow: none !important;
        border: none !important;
      }
      
      /* Reset de margens e paddings */
      body, html {
        margin: 0 !important;
        padding: 0 !important;
        background: white !important;
      }
      
      .main-content, .page-container {
        margin: 0 !important;
        padding: 0 !important;
        max-width: 100% !important;
      }
      
      /* Tabela ocupa largura total */
      .dre-table {
        width: 100% !important;
        font-size: 11px !important;
      }
      
      .dre-table th:first-child,
      .dre-table td:first-child {
        position: static !important;
      }
      
      /* Esconder legenda */
      .mt-6.flex.flex-wrap {
        display: none !important;
      }
      
      /* Titulo para impressão */
      .card::before {
        content: "DRE - Demonstrativo de Resultado do ExercÃ­cio <%= ano %>";
        display: block;
        font-size: 16px;
        font-weight: bold;
        text-align: center;
        padding: 10px 0 15px 0;
        border-bottom: 2px solid #333;
        margin-bottom: 10px;
        visibility: visible;
      }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
    });
  </script>
</body>
</html>