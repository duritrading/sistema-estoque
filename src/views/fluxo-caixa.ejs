<!-- views/fluxo-caixa.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fluxo de Caixa | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'fluxo-caixa' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container" style="max-width: 1400px;">
      
      <!-- Page Header -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-secondary-900 flex items-center gap-3">
            <i data-lucide="wallet" class="w-8 h-8 text-primary-600"></i>
            Controle Financeiro
          </h1>
          <p class="mt-1 text-secondary-500 flex items-center gap-2">
            Gestão centralizada de entradas e saídas
            <% if (filtros.periodo !== 'mes-atual') { %>
              <span class="inline-flex items-center px-2 py-1 bg-blue-100 text-blue-700 text-xs font-medium rounded">
                <% if (filtros.periodo === 'mes-passado') { %>Mês Anterior<% } %>
                <% if (filtros.periodo === 'ultimos-30') { %>Últimos 30 dias<% } %>
                <% if (filtros.periodo === 'custom') { %>
                  <%= new Date(filtros.data_inicio).toLocaleDateString('pt-BR') %> - <%= new Date(filtros.data_fim).toLocaleDateString('pt-BR') %>
                <% } %>
              </span>
            <% } %>
          </p>
        </div>
        <button type="button" onclick="abrirModal()" class="btn btn-primary">
          <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
          Novo Lançamento
        </button>
      </div>

      <!-- Filtros -->
      <div class="card mb-6">
        <div class="card-body py-4">
          <div class="flex flex-wrap items-end gap-4">
            <!-- Período -->
            <div class="min-w-[160px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block flex items-center gap-1">
                <i data-lucide="calendar" class="w-3 h-3"></i>
                Período
              </label>
              <select id="periodoSelect" class="form-select" onchange="toggleCustomDates()">
                <option value="mes-atual" <%= filtros.periodo === 'mes-atual' ? 'selected' : '' %>>Mês Atual</option>
                <option value="mes-passado" <%= filtros.periodo === 'mes-passado' ? 'selected' : '' %>>Mês Anterior</option>
                <option value="ultimos-30" <%= filtros.periodo === 'ultimos-30' ? 'selected' : '' %>>Últimos 30 dias</option>
                <option value="custom" <%= filtros.periodo === 'custom' ? 'selected' : '' %>>Período Personalizado</option>
              </select>
            </div>

            <!-- Datas Personalizadas -->
            <div id="customDateGroup" class="items-end gap-3 p-3 bg-secondary-50 rounded-lg border border-secondary-200 <%= filtros.periodo === 'custom' ? 'flex' : 'hidden' %>">
              <div>
                <label class="text-xs font-medium text-secondary-500 mb-1 block">De:</label>
                <input type="date" id="dataInicio" class="form-input" value="<%= filtros.data_inicio || '' %>">
              </div>
              <div>
                <label class="text-xs font-medium text-secondary-500 mb-1 block">Até:</label>
                <input type="date" id="dataFim" class="form-input" value="<%= filtros.data_fim || '' %>">
              </div>
            </div>

            <!-- Tipo -->
            <div class="min-w-[140px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block flex items-center gap-1">
                <i data-lucide="filter" class="w-3 h-3"></i>
                Tipo
              </label>
              <select id="tipoSelect" class="form-select">
                <option value="">Todos os tipos</option>
                <option value="CREDITO" <%= filtros.tipo === 'CREDITO' ? 'selected' : '' %>>Entradas</option>
                <option value="DEBITO" <%= filtros.tipo === 'DEBITO' ? 'selected' : '' %>>Saídas</option>
              </select>
            </div>

            <!-- Buscar -->
            <div class="min-w-[200px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block flex items-center gap-1">
                <i data-lucide="search" class="w-3 h-3"></i>
                Buscar
              </label>
              <input type="text" id="searchInput" class="form-input" placeholder="Descrição ou categoria..." value="<%= filtros.pesquisar || '' %>" onkeypress="if(event.key==='Enter') aplicarFiltros()">
            </div>

            <!-- Botões -->
            <div class="flex gap-2 ml-auto">
              <button type="button" onclick="aplicarFiltros()" class="btn btn-primary">
                <i data-lucide="search" class="w-4 h-4 mr-1"></i>
                Filtrar
              </button>
              <button type="button" onclick="limparFiltros()" class="btn btn-secondary">
                <i data-lucide="x" class="w-4 h-4 mr-1"></i>
                Limpar
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Métricas -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
        <!-- Receitas em Aberto -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-cyan-500 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-cyan-100 flex items-center justify-center">
              <i data-lucide="dollar-sign" class="w-5 h-5 text-cyan-600"></i>
            </div>
            <span class="text-xs font-medium text-secondary-500 uppercase">Receitas em Aberto</span>
          </div>
          <p class="text-2xl font-bold text-cyan-600">
            R$ <%= metricas.receitasAbertas.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
          </p>
        </div>

        <!-- Receitas Realizadas -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-green-500 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center">
              <i data-lucide="trending-up" class="w-5 h-5 text-green-600"></i>
            </div>
            <span class="text-xs font-medium text-secondary-500 uppercase">Receitas Realizadas</span>
          </div>
          <p class="text-2xl font-bold text-green-600">
            R$ <%= metricas.receitasRealizadas.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
          </p>
        </div>

        <!-- Despesas em Aberto -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-orange-500 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-orange-100 flex items-center justify-center">
              <i data-lucide="credit-card" class="w-5 h-5 text-orange-600"></i>
            </div>
            <span class="text-xs font-medium text-secondary-500 uppercase">Despesas em Aberto</span>
          </div>
          <p class="text-2xl font-bold text-orange-600">
            R$ <%= metricas.despesasAbertas.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
          </p>
        </div>

        <!-- Despesas Realizadas -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-red-500 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-red-100 flex items-center justify-center">
              <i data-lucide="trending-down" class="w-5 h-5 text-red-600"></i>
            </div>
            <span class="text-xs font-medium text-secondary-500 uppercase">Despesas Realizadas</span>
          </div>
          <p class="text-2xl font-bold text-red-600">
            R$ <%= metricas.despesasRealizadas.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
          </p>
        </div>

        <!-- Saldo Total -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 <%= metricas.saldoTotal >= 0 ? 'border-violet-500' : 'border-red-500' %> hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg <%= metricas.saldoTotal >= 0 ? 'bg-violet-100' : 'bg-red-100' %> flex items-center justify-center">
              <i data-lucide="wallet" class="w-5 h-5 <%= metricas.saldoTotal >= 0 ? 'text-violet-600' : 'text-red-600' %>"></i>
            </div>
            <span class="text-xs font-medium text-secondary-500 uppercase">Saldo Total</span>
          </div>
          <p class="text-2xl font-bold <%= metricas.saldoTotal >= 0 ? 'text-violet-600' : 'text-red-600' %>">
            R$ <%= metricas.saldoTotal.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
          </p>
        </div>
      </div>

      <!-- Tabela -->
      <div class="card">
        <div class="card-header flex items-center justify-between">
          <h2 class="text-lg font-semibold text-secondary-900 flex items-center gap-2">
            <i data-lucide="list" class="w-5 h-5 text-primary-600"></i>
            Movimentações Financeiras
          </h2>
          <div class="flex items-center gap-4">
            <% if (filtros.pesquisar || filtros.tipo || filtros.periodo !== 'mes-atual') { %>
              <span class="inline-flex items-center gap-1 px-2 py-1 bg-blue-100 text-blue-700 text-xs font-medium rounded">
                <i data-lucide="filter" class="w-3 h-3"></i>
                Filtros aplicados
              </span>
            <% } %>
            <span class="text-sm text-secondary-500"><%= lancamentos.length %> registro(s)</span>
          </div>
        </div>

        <div class="table-container">
          <table class="table" id="tableMovimentacoes">
            <thead>
              <tr>
                <th class="w-12 text-center">
                  <input type="checkbox" id="selectAll" class="w-4 h-4 rounded border-secondary-300" onchange="toggleSelectAll(this)">
                </th>
                <th>Data</th>
                <th>Descrição</th>
                <th>Categoria</th>
                <th>Tipo</th>
                <th class="text-right">Valor</th>
                <th class="text-center">Status</th>
                <th class="text-right">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (lancamentos && lancamentos.length > 0) { %>
                <% lancamentos.forEach(function(item) { %>
                  <tr class="transaction-row" data-id="<%= item.id %>">
                    <td class="text-center">
                      <input type="checkbox" class="item-checkbox w-4 h-4 rounded border-secondary-300" value="<%= item.id %>" onchange="updateBulkActions()">
                    </td>
                    <td class="font-mono text-sm text-secondary-600">
                      <%= new Date(item.data_operacao).toLocaleDateString('pt-BR', {timeZone: 'UTC'}) %>
                    </td>
                    <td>
                      <div class="flex flex-col">
                        <span class="font-medium text-secondary-900"><%= item.descricao %></span>
                        <% if (item.observacao) { %>
                          <span class="text-xs text-secondary-500"><%= item.observacao %></span>
                        <% } %>
                      </div>
                    </td>
                    <td>
                      <span class="inline-flex px-2 py-1 bg-secondary-100 text-secondary-600 text-xs font-medium rounded">
                        <%= item.categoria_nome || 'Sem categoria' %>
                      </span>
                    </td>
                    <td>
                      <span class="badge <%= item.tipo === 'CREDITO' ? 'badge-success' : 'badge-danger' %>">
                        <i data-lucide="<%= item.tipo === 'CREDITO' ? 'trending-up' : 'trending-down' %>" class="w-3 h-3 mr-1"></i>
                        <%= item.tipo === 'CREDITO' ? 'Entrada' : 'Saída' %>
                      </span>
                    </td>
                    <td class="text-right">
                      <span class="font-semibold font-mono <%= item.tipo === 'CREDITO' ? 'text-green-600' : 'text-red-600' %>">
                        <%= item.tipo === 'CREDITO' ? '+' : '-' %> R$ <%= parseFloat(item.valor).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
                      </span>
                    </td>
                    <td class="text-center">
                      <span class="badge badge-success">
                        <i data-lucide="check" class="w-3 h-3 mr-1"></i>
                        Realizado
                      </span>
                    </td>
                    <td class="text-right">
                      <% if (item.descricao && (item.descricao.includes('Recebimento Parcela') || item.descricao.includes('Pagamento:'))) { %>
                        <form action="/fluxo-caixa/estornar/<%= item.id %>" method="POST" class="inline" onsubmit="return confirm('ATENÇÃO: Estornar este lançamento irá reverter o pagamento da conta associada. Continuar?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-sm btn-secondary text-yellow-600" title="Estornar">
                            <i data-lucide="undo-2" class="w-3 h-3 mr-1"></i>
                            Estornar
                          </button>
                        </form>
                      <% } else { %>
                        <form action="/fluxo-caixa/delete/<%= item.id %>" method="POST" class="inline" onsubmit="return confirm('Confirma a exclusão deste lançamento?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-sm btn-secondary text-danger-600" title="Excluir">
                            <i data-lucide="trash-2" class="w-3 h-3 mr-1"></i>
                            Excluir
                          </button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="8">
                    <div class="py-12 text-center">
                      <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mx-auto mb-4">
                        <i data-lucide="file-x" class="w-8 h-8 text-secondary-400"></i>
                      </div>
                      <h3 class="text-lg font-medium text-secondary-900 mb-2">Nenhuma movimentação encontrada</h3>
                      <p class="text-secondary-500">Cadastre seu primeiro lançamento</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
  </div>

  <!-- Bulk Actions Bar -->
  <div id="bulkActionsBar" class="fixed bottom-6 left-1/2 -translate-x-1/2 translate-y-24 opacity-0 pointer-events-none bg-primary-700 text-white px-6 py-4 rounded-xl shadow-2xl flex items-center gap-4 z-50 transition-all duration-300">
    <span class="font-semibold"><span id="selectedCount">0</span> item(s) selecionado(s)</span>
    <div class="flex gap-3 ml-4">
      <button onclick="clearSelection()" class="px-4 py-2 bg-white/20 text-white rounded-lg text-sm font-medium hover:bg-white/30 transition-colors">
        Cancelar
      </button>
      <button onclick="showDeleteConfirmation()" class="px-4 py-2 bg-red-500 text-white rounded-lg text-sm font-medium hover:bg-red-600 transition-colors flex items-center gap-2">
        <i data-lucide="trash-2" class="w-4 h-4"></i>
        Excluir Selecionados
      </button>
    </div>
  </div>

  <!-- Modal Confirmação Exclusão em Massa -->
  <div id="confirmModal" class="fixed inset-0 bg-black bg-opacity-50 z-[60] hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 p-6">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center">
          <i data-lucide="alert-circle" class="w-6 h-6 text-red-600"></i>
        </div>
        <h3 class="text-lg font-bold text-secondary-900">Confirmar Exclusão em Massa</h3>
      </div>
      <div class="mb-6">
        <p class="text-secondary-600 mb-4">
          Você está prestes a excluir <strong id="confirmCount">0</strong> lançamento(s) do fluxo de caixa.
        </p>
        <div class="bg-yellow-50 border-l-4 border-yellow-500 p-4 rounded">
          <p class="text-sm text-yellow-800">
            <strong>Atenção:</strong> Lançamentos vinculados a contas a receber/pagar não serão excluídos e você receberá um relatório detalhado.
          </p>
        </div>
      </div>
      <div class="flex justify-end gap-3">
        <button onclick="closeConfirmModal()" class="btn btn-secondary">Cancelar</button>
        <button onclick="executeBulkDelete()" class="btn bg-red-600 text-white hover:bg-red-700">Confirmar Exclusão</button>
      </div>
    </div>
  </div>

  <!-- Modal Resultados -->
  <div id="resultsModal" class="fixed inset-0 bg-black bg-opacity-50 z-[60] hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 p-6">
      <h3 class="text-lg font-bold text-secondary-900 mb-4">Resultado da Exclusão</h3>
      <div class="space-y-2 mb-4">
        <p class="text-secondary-600"><strong>Total processado:</strong> <span id="resultTotal">0</span></p>
        <p class="text-secondary-600"><strong>Excluídos com sucesso:</strong> <span id="resultSuccess" class="text-green-600 font-semibold">0</span></p>
        <p class="text-secondary-600"><strong>Bloqueados (vinculados):</strong> <span id="resultBlocked" class="text-yellow-600 font-semibold">0</span></p>
        <p class="text-secondary-600"><strong>Erros:</strong> <span id="resultErrors" class="text-red-600 font-semibold">0</span></p>
      </div>
      <div id="resultsList" class="max-h-64 overflow-y-auto space-y-2 mb-4"></div>
      <div class="flex justify-end">
        <button onclick="closeResultsModal()" class="btn btn-secondary">Fechar</button>
      </div>
    </div>
  </div>

  <!-- Modal Novo Lançamento -->
  <div id="modalLancamento" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-xl mx-4 max-h-[90vh] overflow-y-auto">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between sticky top-0 bg-white">
        <h2 class="text-lg font-bold text-secondary-900 flex items-center gap-2">
          <i data-lucide="plus-circle" class="w-5 h-5 text-primary-600"></i>
          Novo Lançamento Financeiro
        </h2>
        <button type="button" onclick="fecharModal()" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      
      <form action="/fluxo-caixa/lancamento" method="POST" class="p-6">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Data Operação -->
          <div class="form-group">
            <label for="data_operacao" class="form-label">
              <i data-lucide="calendar" class="w-4 h-4 mr-1"></i>
              Data da Operação *
            </label>
            <input type="date" id="data_operacao" name="data_operacao" class="form-input" value="<%= hoje %>" required>
          </div>
          
          <!-- Tipo -->
          <div class="form-group">
            <label for="tipo" class="form-label">
              <i data-lucide="arrow-down-up" class="w-4 h-4 mr-1"></i>
              Tipo de Movimento *
            </label>
            <select id="tipo" name="tipo" class="form-select" required>
              <option value="">Selecione o tipo...</option>
              <option value="CREDITO">Entrada (Crédito)</option>
              <option value="DEBITO">Saída (Débito)</option>
            </select>
          </div>

          <!-- Valor -->
          <div class="form-group">
            <label for="valor" class="form-label">
              <i data-lucide="dollar-sign" class="w-4 h-4 mr-1"></i>
              Valor (R$) *
            </label>
            <input type="number" id="valor" name="valor" class="form-input" step="0.01" min="0.01" placeholder="0,00" required>
          </div>
          
          <!-- Categoria -->
          <div class="form-group">
            <label for="categoria_id" class="form-label">
              <i data-lucide="tag" class="w-4 h-4 mr-1"></i>
              Categoria *
            </label>
            <select id="categoria_id" name="categoria_id" class="form-select" required>
              <option value="">Selecione uma categoria...</option>
              <% categorias.forEach(function(cat) { %>
                <option value="<%= cat.id %>"><%= cat.nome %></option>
              <% }); %>
            </select>
          </div>

          <!-- Descrição -->
          <div class="form-group md:col-span-2">
            <label for="descricao" class="form-label">
              <i data-lucide="file-text" class="w-4 h-4 mr-1"></i>
              Descrição *
            </label>
            <input type="text" id="descricao" name="descricao" class="form-input" placeholder="Descreva a movimentação financeira..." required>
          </div>
        </div>
        
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-secondary-200">
          <button type="button" onclick="fecharModal()" class="btn btn-secondary">
            Cancelar
          </button>
          <button type="submit" class="btn btn-primary">
            <i data-lucide="save" class="w-4 h-4 mr-2"></i>
            Salvar Lançamento
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- CSRF Token para JS -->
  <input type="hidden" id="csrfToken" value="<%= csrfToken %>">

  <script>
    // Inicializa ícones
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
    });

    // Modal Lançamento
    function abrirModal() {
      var modal = document.getElementById('modalLancamento');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      lucide.createIcons();
      
      setTimeout(function() {
        document.getElementById('data_operacao').focus();
      }, 100);
    }

    function fecharModal() {
      var modal = document.getElementById('modalLancamento');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }

    // Filtros
    function toggleCustomDates() {
      var periodo = document.getElementById('periodoSelect').value;
      var customGroup = document.getElementById('customDateGroup');
      if (periodo === 'custom') {
        customGroup.classList.remove('hidden');
        customGroup.classList.add('flex');
      } else {
        customGroup.classList.add('hidden');
        customGroup.classList.remove('flex');
      }
    }

    function aplicarFiltros() {
      var periodo = document.getElementById('periodoSelect').value;
      var pesquisar = document.getElementById('searchInput').value;
      var tipo = document.getElementById('tipoSelect').value;
      
      var params = [];
      
      if (periodo) params.push('periodo=' + periodo);
      if (pesquisar) params.push('pesquisar=' + encodeURIComponent(pesquisar));
      if (tipo) params.push('tipo=' + tipo);
      
      if (periodo === 'custom') {
        var dataInicio = document.getElementById('dataInicio').value;
        var dataFim = document.getElementById('dataFim').value;
        if (dataInicio) params.push('data_inicio=' + dataInicio);
        if (dataFim) params.push('data_fim=' + dataFim);
      }
      
      window.location.href = '/fluxo-caixa?' + params.join('&');
    }

    function limparFiltros() {
      window.location.href = '/fluxo-caixa';
    }

    // Bulk Actions
    function updateBulkActions() {
      var checkboxes = document.querySelectorAll('.item-checkbox:checked');
      var count = checkboxes.length;
      var bar = document.getElementById('bulkActionsBar');
      var countElement = document.getElementById('selectedCount');
      
      countElement.textContent = count;
      
      // Update row highlighting
      document.querySelectorAll('.transaction-row').forEach(function(row) {
        row.classList.remove('bg-blue-50');
      });
      
      checkboxes.forEach(function(cb) {
        cb.closest('.transaction-row').classList.add('bg-blue-50');
      });
      
      // Show/hide bar
      if (count > 0) {
        bar.classList.remove('translate-y-24', 'opacity-0', 'pointer-events-none');
        bar.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
      } else {
        bar.classList.add('translate-y-24', 'opacity-0', 'pointer-events-none');
        bar.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
      }
      
      // Update select all checkbox
      var allCheckboxes = document.querySelectorAll('.item-checkbox');
      var selectAllCheckbox = document.getElementById('selectAll');
      selectAllCheckbox.checked = allCheckboxes.length > 0 && count === allCheckboxes.length;
      
      lucide.createIcons();
    }

    function toggleSelectAll(checkbox) {
      var itemCheckboxes = document.querySelectorAll('.item-checkbox');
      itemCheckboxes.forEach(function(cb) {
        cb.checked = checkbox.checked;
      });
      updateBulkActions();
    }

    function clearSelection() {
      document.querySelectorAll('.item-checkbox').forEach(function(cb) {
        cb.checked = false;
      });
      document.getElementById('selectAll').checked = false;
      updateBulkActions();
    }

    function showDeleteConfirmation() {
      var count = document.querySelectorAll('.item-checkbox:checked').length;
      document.getElementById('confirmCount').textContent = count;
      var modal = document.getElementById('confirmModal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      lucide.createIcons();
    }

    function closeConfirmModal() {
      var modal = document.getElementById('confirmModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    function executeBulkDelete() {
      var checkboxes = document.querySelectorAll('.item-checkbox:checked');
      var ids = Array.from(checkboxes).map(function(cb) { return cb.value; });
      var csrfToken = document.getElementById('csrfToken').value;
      
      closeConfirmModal();
      
      fetch('/fluxo-caixa/bulk-delete', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        body: JSON.stringify({ ids: ids })
      })
      .then(function(response) { return response.json(); })
      .then(function(data) {
        if (data.success) {
          showResults(data.resultados);
          setTimeout(function() {
            window.location.reload();
          }, 3000);
        } else {
          alert('Erro: ' + data.message);
        }
      })
      .catch(function(error) {
        alert('Erro ao processar exclusão: ' + error.message);
      });
    }

    function showResults(resultados) {
      document.getElementById('resultTotal').textContent = resultados.total;
      document.getElementById('resultSuccess').textContent = resultados.excluidos;
      document.getElementById('resultBlocked').textContent = resultados.bloqueados;
      document.getElementById('resultErrors').textContent = resultados.erros;
      
      var listContainer = document.getElementById('resultsList');
      listContainer.innerHTML = '';
      
      resultados.detalhes.forEach(function(detalhe) {
        var item = document.createElement('div');
        var bgClass = detalhe.status === 'excluido' ? 'bg-green-50 text-green-700' : 
                      detalhe.status === 'bloqueado' ? 'bg-yellow-50 text-yellow-700' : 'bg-red-50 text-red-700';
        
        var iconName = detalhe.status === 'excluido' ? 'check' : 
                       detalhe.status === 'bloqueado' ? 'alert-triangle' : 'x';
        
        var text = detalhe.status === 'excluido' ? 'Excluído' : 
                   detalhe.status === 'bloqueado' ? 'Bloqueado: ' + detalhe.motivo : 'Erro: ' + detalhe.motivo;
        
        item.className = 'p-3 rounded-lg flex items-center gap-3 text-sm ' + bgClass;
        item.innerHTML = '<i data-lucide="' + iconName + '" class="w-4 h-4 flex-shrink-0"></i><span>ID ' + detalhe.id + ': ' + text + '</span>';
        
        listContainer.appendChild(item);
      });
      
      var modal = document.getElementById('resultsModal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      lucide.createIcons();
    }

    function closeResultsModal() {
      var modal = document.getElementById('resultsModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    // Event listeners
    document.getElementById('modalLancamento').addEventListener('click', function(e) {
      if (e.target === this) fecharModal();
    });

    document.getElementById('confirmModal').addEventListener('click', function(e) {
      if (e.target === this) closeConfirmModal();
    });

    document.getElementById('resultsModal').addEventListener('click', function(e) {
      if (e.target === this) closeResultsModal();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        fecharModal();
        closeConfirmModal();
        closeResultsModal();
      }
    });

    // Form validation
    document.querySelector('#modalLancamento form').addEventListener('submit', function(e) {
      var valor = document.getElementById('valor').value;
      var tipo = document.getElementById('tipo').value;
      var descricao = document.getElementById('descricao').value;
      var categoria = document.getElementById('categoria_id').value;
      
      if (!valor || !tipo || !descricao || !categoria) {
        e.preventDefault();
        alert('Por favor, preencha todos os campos obrigatórios.');
      }
    });
  </script>
</body>
</html>
