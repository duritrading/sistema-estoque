<!-- partials/sidebar.ejs -->
<aside id="sidebar" style="position:fixed;left:0;top:0;height:100vh;width:256px;background-color:#0f172a;color:#fff;z-index:40;transition:width 0.3s ease;display:flex;flex-direction:column;overflow:hidden;">
  
  <!-- Logo + Toggle -->
  <div style="padding:16px;border-bottom:1px solid #1e293b;display:flex;align-items:center;justify-content:space-between;min-height:72px;">
    <a href="/" style="display:flex;align-items:center;gap:12px;text-decoration:none;overflow:hidden;">
      <img src="/logo-of.png" alt="OF" style="width:40px;height:40px;border-radius:8px;object-fit:contain;flex-shrink:0;">
      <div id="logoText" style="overflow:hidden;white-space:nowrap;">
        <h1 style="font-size:16px;font-weight:700;color:#fff;margin:0;">OF Distribuidora</h1>
        <p style="font-size:11px;color:#94a3b8;margin:0;">Sistema de Gestão</p>
      </div>
    </a>
    
    <button type="button" id="sidebarToggle" style="padding:8px;border-radius:8px;background:transparent;border:none;color:#94a3b8;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;" onmouseover="this.style.backgroundColor='#1e293b';this.style.color='#fff'" onmouseout="this.style.backgroundColor='transparent';this.style.color='#94a3b8'">
      <svg id="iconClose" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect width="18" height="18" x="3" y="3" rx="2"></rect>
        <line x1="9" x2="9" y1="3" y2="21"></line>
        <path d="m16 15-3-3 3-3"></path>
      </svg>
      <svg id="iconOpen" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;">
        <rect width="18" height="18" x="3" y="3" rx="2"></rect>
        <line x1="9" x2="9" y1="3" y2="21"></line>
        <path d="m14 9 3 3-3 3"></path>
      </svg>
    </button>
  </div>

  <!-- Navigation -->
  <nav style="flex:1;overflow-y:auto;overflow-x:hidden;padding:16px 0;">
    
    <div class="nav-section">Principal</div>
    <a href="/" class="nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>">
      <i data-lucide="layout-dashboard"></i>
      <span class="nav-text">Dashboard</span>
    </a>

    <div class="nav-section">Estoque</div>
    <a href="/produtos" class="nav-link <%= currentPage === 'produtos' ? 'active' : '' %>">
      <i data-lucide="box"></i>
      <span class="nav-text">Produtos</span>
    </a>
    <a href="/movimentacoes" class="nav-link <%= currentPage === 'movimentacoes' ? 'active' : '' %>">
      <i data-lucide="arrow-left-right"></i>
      <span class="nav-text">Movimentações</span>
    </a>

    <div class="nav-section">Financeiro</div>
    <a href="/contas-a-receber" class="nav-link <%= currentPage === 'contas-a-receber' ? 'active' : '' %>">
      <i data-lucide="trending-up"></i>
      <span class="nav-text">Contas a Receber</span>
    </a>
    <a href="/contas-a-pagar" class="nav-link <%= currentPage === 'contas-a-pagar' ? 'active' : '' %>">
      <i data-lucide="trending-down"></i>
      <span class="nav-text">Contas a Pagar</span>
    </a>
    <a href="/fluxo-caixa" class="nav-link <%= currentPage === 'fluxo-caixa' ? 'active' : '' %>">
      <i data-lucide="wallet"></i>
      <span class="nav-text">Fluxo de Caixa</span>
    </a>
    <a href="/inadimplencia" class="nav-link <%= currentPage === 'inadimplencia' ? 'active' : '' %>">
      <i data-lucide="alert-triangle"></i>
      <span class="nav-text">Inadimplência</span>
    </a>
    <a href="/dre" class="nav-link <%= currentPage === 'dre' ? 'active' : '' %>">
      <i data-lucide="file-bar-chart"></i>
      <span class="nav-text">DRE</span>
    </a>

    <div class="nav-section">Cadastros</div>
    <a href="/clientes" class="nav-link <%= currentPage === 'clientes' ? 'active' : '' %>">
      <i data-lucide="users"></i>
      <span class="nav-text">Clientes</span>
    </a>
    <a href="/fornecedores" class="nav-link <%= currentPage === 'fornecedores' ? 'active' : '' %>">
      <i data-lucide="truck"></i>
      <span class="nav-text">Fornecedores</span>
    </a>
    <a href="/rcas" class="nav-link <%= currentPage === 'rcas' ? 'active' : '' %>">
      <i data-lucide="user-check"></i>
      <span class="nav-text">RCAs</span>
    </a>

    <div class="nav-section">Operações</div>
    <a href="/entregas" class="nav-link <%= currentPage === 'entregas' ? 'active' : '' %>">
      <i data-lucide="map-pin"></i>
      <span class="nav-text">Entregas</span>
    </a>
    <a href="/comissoes" class="nav-link <%= currentPage === 'comissoes' ? 'active' : '' %>">
      <i data-lucide="percent"></i>
      <span class="nav-text">Comissões</span>
    </a>

    <div class="nav-section">Sistema</div>
    <a href="/usuarios" class="nav-link <%= currentPage === 'usuarios' ? 'active' : '' %>">
      <i data-lucide="shield"></i>
      <span class="nav-text">Usuários</span>
    </a>
  </nav>
</aside>

<style>
  .nav-section {
    padding: 8px 24px;
    font-size: 11px;
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 16px;
    white-space: nowrap;
  }
  .nav-section:first-child { margin-top: 0; }
  
  .nav-link {
    display: flex;
    align-items: center;
    padding: 12px 24px;
    color: #cbd5e1;
    text-decoration: none;
    border-left: 4px solid transparent;
    gap: 12px;
    white-space: nowrap;
  }
  .nav-link:hover {
    background-color: #1e293b;
    color: #ffffff;
  }
  .nav-link.active {
    background-color: #1e293b;
    color: #ffffff;
    border-left-color: #3b82f6;
  }
  .nav-link i, .nav-link svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .nav-text {
    overflow: hidden;
  }
  
  .main-content {
    margin-left: 256px;
    transition: margin-left 0.3s ease;
  }
  
  /* Collapsed state classes */
  .sidebar-collapsed-text { display: none !important; }
  .sidebar-collapsed-section { display: none !important; }
</style>

<script>
// Limpar estado anterior que pode estar bugado
localStorage.removeItem('sidebarCollapsed');

var sidebarExpanded = true;

document.getElementById('sidebarToggle').onclick = function() {
  var sidebar = document.getElementById('sidebar');
  var logoText = document.getElementById('logoText');
  var iconClose = document.getElementById('iconClose');
  var iconOpen = document.getElementById('iconOpen');
  var mainContent = document.querySelector('.main-content');
  var navTexts = document.querySelectorAll('.nav-text');
  var navSections = document.querySelectorAll('.nav-section');
  
  sidebarExpanded = !sidebarExpanded;
  
  if (sidebarExpanded) {
    // EXPANDIR
    sidebar.style.width = '256px';
    logoText.style.display = 'block';
    iconClose.style.display = 'block';
    iconOpen.style.display = 'none';
    if (mainContent) mainContent.style.marginLeft = '256px';
    navTexts.forEach(function(el) { el.style.display = 'inline'; });
    navSections.forEach(function(el) { el.style.display = 'block'; });
  } else {
    // COLAPSAR
    sidebar.style.width = '72px';
    logoText.style.display = 'none';
    iconClose.style.display = 'none';
    iconOpen.style.display = 'block';
    if (mainContent) mainContent.style.marginLeft = '72px';
    navTexts.forEach(function(el) { el.style.display = 'none'; });
    navSections.forEach(function(el) { el.style.display = 'none'; });
  }
  
  // Re-render icons
  setTimeout(function() {
    if (typeof lucide !== 'undefined') lucide.createIcons();
  }, 100);
};
</script>
