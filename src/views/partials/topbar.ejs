<!-- partials/topbar.ejs -->
<header class="topbar">
  <div class="flex items-center gap-4">
    <!-- Page Title (optional, can be passed) -->
    <% if (typeof pageTitle !== 'undefined') { %>
      <h1 class="text-xl font-semibold text-secondary-900"><%= pageTitle %></h1>
    <% } %>
  </div>

  <div class="flex items-center gap-4">
    <!-- Search (optional) -->
    <div class="relative hidden md:block">
      <input 
        type="text" 
        placeholder="Buscar..." 
        class="form-input w-64 pl-10 py-2"
      >
      <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary-400"></i>
    </div>

    <!-- Notifications -->
    <button class="btn-icon btn-ghost relative">
      <i data-lucide="bell" class="w-5 h-5 text-secondary-500"></i>
      <span class="absolute -top-1 -right-1 w-4 h-4 bg-danger-500 rounded-full text-[10px] text-white flex items-center justify-center">3</span>
    </button>

    <!-- User Menu -->
    <div class="dropdown">
      <button class="flex items-center gap-3 hover:bg-secondary-50 rounded-lg px-3 py-2 transition-colors" onclick="this.nextElementSibling.classList.toggle('show')">
        <div class="w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center">
          <span class="text-sm font-medium text-primary-700">
            <%= user && user.nomeCompleto ? user.nomeCompleto.charAt(0).toUpperCase() : 'U' %>
          </span>
        </div>
        <div class="hidden sm:block text-left">
          <p class="text-sm font-medium text-secondary-900">
            <%= user ? (user.nomeCompleto || user.username) : 'Usuário' %>
          </p>
          <p class="text-xs text-secondary-500">Administrador</p>
        </div>
        <i data-lucide="chevron-down" class="w-4 h-4 text-secondary-400"></i>
      </button>
      
      <div class="dropdown-menu">
        <a href="/usuarios" class="dropdown-item flex items-center gap-2">
          <i data-lucide="user" class="w-4 h-4"></i>
          Meu Perfil
        </a>
        <a href="/usuarios" class="dropdown-item flex items-center gap-2">
          <i data-lucide="settings" class="w-4 h-4"></i>
          Configurações
        </a>
        <hr class="my-1 border-secondary-200">
        <a href="/logout" class="dropdown-item flex items-center gap-2 text-danger-600">
          <i data-lucide="log-out" class="w-4 h-4"></i>
          Sair
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.dropdown')) {
      document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('show'));
    }
  });
</script>
