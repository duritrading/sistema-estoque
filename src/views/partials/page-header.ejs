<!-- partials/page-header.ejs -->
<!-- 
  Props:
  - title: string (título da página)
  - subtitle: string (descrição - opcional)
  - breadcrumbs: array of {label, url} (opcional)
  - actions: HTML string (botões de ação - opcional)
-->

<div class="mb-6">
  <% if (typeof breadcrumbs !== 'undefined' && breadcrumbs.length > 0) { %>
    <nav class="flex mb-3" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 text-sm">
        <li>
          <a href="/" class="text-secondary-500 hover:text-secondary-700">
            <i data-lucide="home" class="w-4 h-4"></i>
          </a>
        </li>
        <% breadcrumbs.forEach((crumb, index) => { %>
          <li class="flex items-center">
            <i data-lucide="chevron-right" class="w-4 h-4 text-secondary-400 mx-1"></i>
            <% if (index === breadcrumbs.length - 1) { %>
              <span class="text-secondary-900 font-medium"><%= crumb.label %></span>
            <% } else { %>
              <a href="<%= crumb.url %>" class="text-secondary-500 hover:text-secondary-700"><%= crumb.label %></a>
            <% } %>
          </li>
        <% }); %>
      </ol>
    </nav>
  <% } %>

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-secondary-900"><%= title %></h1>
      <% if (typeof subtitle !== 'undefined') { %>
        <p class="mt-1 text-secondary-500"><%= subtitle %></p>
      <% } %>
    </div>
    
    <% if (typeof actions !== 'undefined') { %>
      <div class="flex items-center gap-3">
        <%- actions %>
      </div>
    <% } %>
  </div>
</div>
