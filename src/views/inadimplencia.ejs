<!-- views/inadimplencia.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inadimplência | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'inadimplencia' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container" style="max-width: 1400px;">
      
      <!-- Page Header -->
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-secondary-900">Inadimplência</h1>
        <p class="mt-1 text-secondary-500">Gerenciamento de contas vencidas</p>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <!-- Total em Atraso -->
        <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-red-500">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-red-100 flex items-center justify-center">
              <i data-lucide="alert-circle" class="w-7 h-7 text-red-600"></i>
            </div>
            <div>
              <p class="text-sm font-medium text-secondary-500 uppercase tracking-wide">Total em Atraso</p>
              <p class="text-3xl font-bold text-red-600">R$ <%= totalEmAtraso.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></p>
              <p class="text-sm text-secondary-500">Valor total vencido</p>
            </div>
          </div>
        </div>

        <!-- Contas Vencidas -->
        <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-yellow-500">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-yellow-100 flex items-center justify-center">
              <i data-lucide="file-text" class="w-7 h-7 text-yellow-600"></i>
            </div>
            <div>
              <p class="text-sm font-medium text-secondary-500 uppercase tracking-wide">Contas Vencidas</p>
              <p class="text-3xl font-bold text-yellow-600"><%= contasVencidas.length %></p>
              <p class="text-sm text-secondary-500">Parcelas em atraso</p>
            </div>
          </div>
        </div>

        <!-- Clientes Inadimplentes -->
        <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-cyan-500">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-cyan-100 flex items-center justify-center">
              <i data-lucide="users" class="w-7 h-7 text-cyan-600"></i>
            </div>
            <div>
              <p class="text-sm font-medium text-secondary-500 uppercase tracking-wide">Clientes Inadimplentes</p>
              <p class="text-3xl font-bold text-cyan-600"><%= clientesInadimplentes %></p>
              <p class="text-sm text-secondary-500">Com parcelas vencidas</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Tabela de Parcelas -->
      <div class="card">
        <div class="card-header flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-primary-600 flex items-center justify-center">
            <i data-lucide="receipt" class="w-6 h-6 text-white"></i>
          </div>
          <div>
            <h2 class="text-xl font-bold text-secondary-900">Parcelas Vencidas e Não Pagas</h2>
            <p class="text-secondary-500">Gerencie contas em atraso e registre pagamentos</p>
          </div>
        </div>
        
        <% if (contasVencidas.length > 0) { %>
          <div class="table-container">
            <table class="table" style="min-width: 1100px;">
              <thead>
                <tr>
                  <th>Cliente</th>
                  <th>Produto</th>
                  <th>Descrição</th>
                  <th class="text-center">Parcela</th>
                  <th class="text-right">Valor</th>
                  <th>Vencimento</th>
                  <th class="text-center">Dias em Atraso</th>
                  <th class="text-right">Ações</th>
                </tr>
              </thead>
              <tbody>
                <% contasVencidas.forEach(function(conta) { %>
                  <tr>
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-primary-100 flex items-center justify-center">
                          <i data-lucide="user" class="w-4 h-4 text-primary-600"></i>
                        </div>
                        <span class="font-medium text-secondary-900"><%= conta.cliente_nome %></span>
                      </div>
                    </td>
                    <td class="text-secondary-600"><%= conta.produto_descricao || '-' %></td>
                    <td class="text-secondary-600 max-w-xs truncate" title="<%= conta.conta_descricao || '' %>">
                      <%= conta.conta_descricao || '-' %>
                    </td>
                    <td class="text-center">
                      <span class="inline-flex items-center px-3 py-1 rounded-md bg-secondary-100 text-secondary-700 text-sm font-semibold">
                        <%= conta.numero_parcela %>/<%= conta.total_parcelas %>
                      </span>
                    </td>
                    <td class="text-right font-semibold text-green-600">
                      R$ <%= parseFloat(conta.valor).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
                    </td>
                    <td class="font-mono text-sm text-secondary-600">
                      <%= new Date(conta.data_vencimento).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %>
                    </td>
                    <td class="text-center">
                      <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-semibold <%= conta.dias_atraso > 90 ? 'bg-red-100 text-red-700' : conta.dias_atraso > 30 ? 'bg-orange-100 text-orange-700' : 'bg-yellow-100 text-yellow-700' %>">
                        <%= conta.dias_atraso %> dias
                      </span>
                    </td>
                    <td class="text-right">
                      <div class="flex justify-end gap-2">
                        <button type="button" 
                                class="btn btn-sm btn-success"
                                data-conta-id="<%= conta.id %>"
                                data-cliente-nome="<%= conta.cliente_nome %>"
                                data-valor="<%= conta.valor %>"
                                data-parcela="<%= conta.numero_parcela %>"
                                data-total="<%= conta.total_parcelas %>"
                                onclick="abrirModalPagamento(this)">
                          <i data-lucide="check-circle" class="w-4 h-4 mr-1"></i>
                          Pagar
                        </button>
                        <form action="/inadimplencia/excluir/<%= conta.id %>" method="POST" class="inline" onsubmit="return confirm('Excluir esta conta?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-sm btn-secondary">
                            <i data-lucide="trash-2" class="w-4 h-4 mr-1"></i>
                            Excluir
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="card-body py-16 text-center">
            <div class="w-20 h-20 rounded-2xl bg-green-100 flex items-center justify-center mx-auto mb-6">
              <i data-lucide="check-circle" class="w-10 h-10 text-green-600"></i>
            </div>
            <h3 class="text-xl font-semibold text-secondary-900 mb-2">Nenhuma conta vencida</h3>
            <p class="text-secondary-500">Todas as contas estão em dia!</p>
          </div>
        <% } %>
      </div>

    </main>
  </div>

  <!-- Modal de Pagamento -->
  <div id="modalPagamento" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4">
      <div class="px-6 py-5 border-b border-secondary-200 bg-secondary-50 rounded-t-2xl flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-primary-600 flex items-center justify-center">
            <i data-lucide="check-circle" class="w-5 h-5 text-white"></i>
          </div>
          <h3 class="text-lg font-bold text-secondary-900">Registrar Pagamento</h3>
        </div>
        <button type="button" onclick="fecharModal()" class="w-10 h-10 rounded-lg bg-secondary-200 hover:bg-secondary-300 flex items-center justify-center text-secondary-600 transition-colors">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      
      <div class="p-6">
        <!-- Info do Pagamento -->
        <div class="space-y-4 mb-6">
          <div class="flex justify-between items-center py-3 border-b border-secondary-100">
            <span class="text-sm font-medium text-secondary-500">Cliente:</span>
            <span class="font-semibold text-secondary-900" id="modalClienteNome">-</span>
          </div>
          <div class="flex justify-between items-center py-3 border-b border-secondary-100">
            <span class="text-sm font-medium text-secondary-500">Parcela:</span>
            <span class="font-semibold text-secondary-900" id="modalParcelaInfo">-</span>
          </div>
          <div class="flex justify-between items-center py-3">
            <span class="text-sm font-medium text-secondary-500">Valor:</span>
            <span class="text-2xl font-bold text-green-600" id="modalValorConta">R$ 0,00</span>
          </div>
        </div>
        
        <!-- Formulário -->
        <form id="formPagamento" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          
          <div class="form-group">
            <label for="dataPagamento" class="form-label">
              Data do Pagamento <span class="text-red-500">*</span>
            </label>
            <input type="date" id="dataPagamento" name="data_pagamento" class="form-input" required>
            <p class="text-xs text-secondary-500 mt-1">Selecione a data em que o pagamento foi recebido</p>
          </div>
        </form>
      </div>
      
      <div class="px-6 py-4 border-t border-secondary-200 bg-secondary-50 rounded-b-2xl flex justify-end gap-3">
        <button type="button" onclick="fecharModal()" class="btn btn-secondary">
          Cancelar
        </button>
        <button type="submit" form="formPagamento" class="btn btn-success">
          <i data-lucide="check" class="w-4 h-4 mr-2"></i>
          Confirmar Pagamento
        </button>
      </div>
    </div>
  </div>

  <script>
    // Inicializa ícones
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
      
      // Data de hoje como padrão
      var hoje = new Date().toISOString().split('T')[0];
      document.getElementById('dataPagamento').value = hoje;
      
      // Fechar modal ao clicar fora
      document.getElementById('modalPagamento').addEventListener('click', function(e) {
        if (e.target === this) fecharModal();
      });
      
      // Fechar com ESC
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') fecharModal();
      });
      
      // Validação do formulário
      document.getElementById('formPagamento').addEventListener('submit', function(e) {
        var dataPagamento = document.getElementById('dataPagamento').value;
        var hoje = new Date().toISOString().split('T')[0];
        
        if (!dataPagamento) {
          e.preventDefault();
          alert('Por favor, selecione a data do pagamento.');
          return;
        }
        
        if (dataPagamento > hoje) {
          e.preventDefault();
          alert('A data de pagamento não pode ser no futuro.');
          return;
        }
        
        if (!confirm('Confirma o recebimento desta parcela na data selecionada?')) {
          e.preventDefault();
        }
      });
    });
    
    // Abrir modal de pagamento usando data attributes
    function abrirModalPagamento(btn) {
      var contaId = btn.dataset.contaId;
      var clienteNome = btn.dataset.clienteNome;
      var valor = parseFloat(btn.dataset.valor);
      var parcela = btn.dataset.parcela;
      var total = btn.dataset.total;
      
      document.getElementById('modalClienteNome').textContent = clienteNome;
      document.getElementById('modalParcelaInfo').textContent = parcela + '/' + total;
      document.getElementById('modalValorConta').textContent = 'R$ ' + valor.toLocaleString('pt-BR', {minimumFractionDigits: 2});
      
      document.getElementById('formPagamento').action = '/inadimplencia/marcar-paga/' + contaId;
      
      var modal = document.getElementById('modalPagamento');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      
      lucide.createIcons();
      
      setTimeout(function() {
        document.getElementById('dataPagamento').focus();
      }, 100);
    }
    
    // Fechar modal
    function fecharModal() {
      var modal = document.getElementById('modalPagamento');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
  </script>
</body>
</html>
