<!-- views/comissoes.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Comissões | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'comissoes' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container">
      
      <!-- Page Header -->
      <div class="mb-6">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-secondary-900">Comissões de RCAs</h1>
            <p class="mt-1 text-secondary-500">Gestão de comissões por produto (RCA + Rian)</p>
          </div>
          
          <!-- Filtros -->
          <form method="GET" action="/comissoes" class="flex flex-wrap items-center gap-3">
            <select name="mes" class="form-select w-32">
              <% for(let m = 1; m <= 12; m++) { %>
                <option value="<%= m %>" <%= filtros.mes == m ? 'selected' : '' %>>
                  <%= new Date(2000, m-1).toLocaleString('pt-BR', {month: 'long'}) %>
                </option>
              <% } %>
            </select>
            
            <select name="ano" class="form-select w-24">
              <% for(let a = new Date().getFullYear(); a >= 2020; a--) { %>
                <option value="<%= a %>" <%= filtros.ano == a ? 'selected' : '' %>><%= a %></option>
              <% } %>
            </select>
            
            <select name="rca_id" class="form-select w-48">
              <option value="">Todos os RCAs</option>
              <% rcasList.forEach(function(rca) { %>
                <option value="<%= rca.id %>" <%= filtros.rca_id == rca.id ? 'selected' : '' %>><%= rca.nome %></option>
              <% }) %>
            </select>
            
            <button type="submit" class="btn btn-primary">
              <i data-lucide="filter" class="w-4 h-4 mr-2"></i>
              Filtrar
            </button>
          </form>
        </div>
      </div>

      <!-- Info Box -->
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
        <div class="flex items-start gap-3">
          <i data-lucide="info" class="w-5 h-5 text-blue-600 mt-0.5"></i>
          <p class="text-sm text-blue-800">
            <strong>Comissão por Produto:</strong> Cada produto tem % de comissão para RCA e % para Rian. 
            Produtos com comissão fixa (R$) usam valor por unidade vendida em vez de percentual.
          </p>
        </div>
      </div>

      <!-- KPIs -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
        <div class="card">
          <div class="card-body text-center">
            <p class="text-xs font-semibold text-secondary-500 uppercase mb-1">Total Vendas</p>
            <p class="text-2xl font-bold text-secondary-900">
              R$ <%= totais.total_vendas.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
            </p>
          </div>
        </div>
        
        <div class="card">
          <div class="card-body text-center">
            <p class="text-xs font-semibold text-secondary-500 uppercase mb-1">Comissões RCA</p>
            <p class="text-2xl font-bold text-green-600">
              R$ <%= totais.total_comissoes.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
            </p>
          </div>
        </div>

        <div class="card">
          <div class="card-body text-center">
            <p class="text-xs font-semibold text-secondary-500 uppercase mb-1">Comissão Rian</p>
            <p class="text-2xl font-bold text-violet-600">
              R$ <%= (totais.total_comissoes_rian || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
            </p>
          </div>
        </div>
        
        <div class="card">
          <div class="card-body text-center">
            <p class="text-xs font-semibold text-secondary-500 uppercase mb-1">RCAs com Vendas</p>
            <p class="text-2xl font-bold text-secondary-900"><%= totais.total_rcas %></p>
          </div>
        </div>
        
        <div class="card">
          <div class="card-body text-center">
            <p class="text-xs font-semibold text-secondary-500 uppercase mb-1">Período</p>
            <p class="text-sm font-semibold text-secondary-900">
              <%= new Date(filtros.periodo_inicio).toLocaleDateString('pt-BR') %> a <%= new Date(filtros.periodo_fim).toLocaleDateString('pt-BR') %>
            </p>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="border-b border-secondary-200 mb-6">
        <nav class="flex gap-4">
          <button type="button" class="tab-btn active pb-3 px-1 text-sm font-medium border-b-2 border-primary-600 text-primary-600" onclick="showTab('rcas', this)">
            <i data-lucide="bar-chart-3" class="w-4 h-4 inline mr-1"></i>
            Vendas por RCA
          </button>
          <button type="button" class="tab-btn pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-secondary-500 hover:text-secondary-700" onclick="showTab('produtos', this)">
            <i data-lucide="package" class="w-4 h-4 inline mr-1"></i>
            Comissão por Produto
          </button>
          <button type="button" class="tab-btn pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-secondary-500 hover:text-secondary-700" onclick="showTab('historico', this)">
            <i data-lucide="history" class="w-4 h-4 inline mr-1"></i>
            Histórico de Pagamentos
          </button>
        </nav>
      </div>

      <!-- Tab: Vendas por RCA -->
      <div id="tab-rcas" class="tab-content">
        <div class="card">
          <div class="table-container">
            <table class="table">
              <thead>
                <tr>
                  <th>RCA</th>
                  <th>Praça</th>
                  <th class="text-center">Vendas</th>
                  <th class="text-right">Valor Vendas</th>
                  <th class="text-right">Comissão RCA</th>
                  <th class="text-right">Comissão Rian</th>
                  <th class="text-right">Ações</th>
                </tr>
              </thead>
              <tbody>
                <% if (rcas.length === 0) { %>
                  <tr>
                    <td colspan="7" class="text-center py-8 text-secondary-500">Nenhum RCA encontrado</td>
                  </tr>
                <% } else { %>
                  <% rcas.forEach(function(rca) { %>
                    <tr>
                      <td class="font-medium text-secondary-900"><%= rca.nome %></td>
                      <td class="text-secondary-600"><%= rca.praca || '-' %></td>
                      <td class="text-center"><%= rca.qtd_vendas %></td>
                      <td class="text-right">R$ <%= rca.vendas_periodo.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                      <td class="text-right font-semibold text-green-600">
                        R$ <%= rca.valor_comissao.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
                      </td>
                      <td class="text-right font-semibold text-violet-600">
                        R$ <%= (rca.valor_comissao_rian || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
                      </td>
                      <td class="text-right">
                        <% if (rca.vendas_periodo > 0) { %>
                          <div class="flex justify-end gap-2">
                            <button type="button" class="btn btn-sm btn-secondary" data-rca-id="<%= rca.id %>" data-rca-nome="<%= rca.nome %>" onclick="verDetalhes(this.dataset.rcaId, this.dataset.rcaNome)">
                              Detalhes
                            </button>
                            <button type="button" class="btn btn-sm btn-primary" data-rca-id="<%= rca.id %>" data-rca-nome="<%= rca.nome %>" onclick="abrirModalGerar(this)">
                              Gerar
                            </button>
                          </div>
                        <% } else { %>
                          <span class="text-secondary-400 text-sm">Sem vendas</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
              <% if (rcas.length > 0) { %>
                <tfoot class="bg-secondary-50">
                  <tr>
                    <td colspan="3" class="font-semibold">TOTAL</td>
                    <td class="text-right font-semibold">R$ <%= totais.total_vendas.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                    <td class="text-right font-semibold text-green-600">R$ <%= totais.total_comissoes.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                    <td class="text-right font-semibold text-violet-600">R$ <%= (totais.total_comissoes_rian || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                    <td></td>
                  </tr>
                </tfoot>
              <% } %>
            </table>
          </div>
        </div>
      </div>

      <!-- Tab: Comissão por Produto -->
      <div id="tab-produtos" class="tab-content hidden">
        <div class="card">
          <div class="card-body pb-0">
            <div class="flex items-center gap-4 mb-4">
              <div class="relative flex-1 max-w-sm">
                <input type="text" id="searchProduto" placeholder="Buscar produto..." class="form-input pl-10" onkeyup="filtrarProdutos()">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary-400"></i>
              </div>
              <p class="text-sm text-secondary-500">Deixe comissão fixa vazia para usar percentual</p>
            </div>
          </div>
          
          <div class="table-container" style="max-height: 600px; overflow-y: auto;">
            <table class="table" id="tabelaProdutos">
              <thead class="sticky top-0 bg-secondary-50">
                <tr>
                  <th>Código</th>
                  <th>Produto</th>
                  <th class="text-center">% RCA</th>
                  <th class="text-center">% Rian</th>
                  <th class="text-center">R$ RCA (fixo)</th>
                  <th class="text-center">R$ Rian (fixo)</th>
                  <th class="text-center">Ação</th>
                </tr>
              </thead>
              <tbody>
                <% produtos.forEach(function(prod) { %>
                  <tr>
                    <td class="font-mono font-medium text-secondary-600"><%= prod.codigo %></td>
                    <td class="text-secondary-900"><%= prod.descricao %></td>
                    <td class="text-center">
                      <div class="flex items-center justify-center gap-1">
                        <input type="number" class="w-16 px-2 py-1 text-center border border-secondary-300 rounded-md focus:ring-2 focus:ring-primary-500"
                               id="comissao-<%= prod.id %>" value="<%= prod.percentual_comissao || 0 %>" step="0.5" min="0" max="100">
                        <span class="text-secondary-500">%</span>
                      </div>
                    </td>
                    <td class="text-center">
                      <div class="flex items-center justify-center gap-1">
                        <input type="number" class="w-16 px-2 py-1 text-center border border-secondary-300 rounded-md focus:ring-2 focus:ring-violet-500"
                               id="comissao-rian-<%= prod.id %>" value="<%= prod.percentual_comissao_rian || 0 %>" step="0.5" min="0" max="100">
                        <span class="text-secondary-500">%</span>
                      </div>
                    </td>
                    <td class="text-center">
                      <div class="flex items-center justify-center gap-1">
                        <span class="text-secondary-400">R$</span>
                        <input type="number" class="w-20 px-2 py-1 text-center border border-secondary-300 rounded-md focus:ring-2 focus:ring-green-500"
                               id="fixa-rca-<%= prod.id %>" value="<%= prod.comissao_fixa_rca || '' %>" step="0.01" min="0" placeholder="-">
                      </div>
                    </td>
                    <td class="text-center">
                      <div class="flex items-center justify-center gap-1">
                        <span class="text-secondary-400">R$</span>
                        <input type="number" class="w-20 px-2 py-1 text-center border border-secondary-300 rounded-md focus:ring-2 focus:ring-violet-500"
                               id="fixa-rian-<%= prod.id %>" value="<%= prod.comissao_fixa_rian || '' %>" step="0.01" min="0" placeholder="-">
                      </div>
                    </td>
                    <td class="text-center">
                      <button type="button" class="btn btn-sm btn-primary" data-produto-id="<%= prod.id %>" onclick="salvarComissaoProduto(this.dataset.produtoId)">
                        Salvar
                      </button>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Tab: Histórico de Pagamentos -->
      <div id="tab-historico" class="tab-content hidden">
        <div class="card">
          <div class="table-container">
            <table class="table">
              <thead>
                <tr>
                  <th>RCA</th>
                  <th>Período</th>
                  <th class="text-right">Valor Vendas</th>
                  <th class="text-right">Comissão RCA</th>
                  <th class="text-right">Comissão Rian</th>
                  <th class="text-center">Status</th>
                  <th class="text-center">Data Pgto</th>
                  <th class="text-right">Ações</th>
                </tr>
              </thead>
              <tbody>
                <% if (comissoes.length === 0) { %>
                  <tr>
                    <td colspan="8" class="text-center py-8 text-secondary-500">Nenhuma comissão registrada neste período</td>
                  </tr>
                <% } else { %>
                  <% comissoes.forEach(function(c) { %>
                    <tr>
                      <td class="font-medium text-secondary-900"><%= c.rca_nome %></td>
                      <td class="text-secondary-600 text-sm">
                        <%= new Date(c.periodo_inicio).toLocaleDateString('pt-BR') %> - <%= new Date(c.periodo_fim).toLocaleDateString('pt-BR') %>
                      </td>
                      <td class="text-right">R$ <%= parseFloat(c.valor_vendas).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                      <td class="text-right font-semibold text-green-600">R$ <%= parseFloat(c.valor_comissao).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                      <td class="text-right font-semibold text-violet-600">R$ <%= parseFloat(c.valor_comissao_rian || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                      <td class="text-center">
                        <span class="badge <%= c.status === 'PAGO' ? 'badge-success' : c.status === 'PENDENTE' ? 'badge-warning' : 'badge-danger' %>">
                          <%= c.status %>
                        </span>
                      </td>
                      <td class="text-center text-secondary-600">
                        <%= c.data_pagamento ? new Date(c.data_pagamento).toLocaleDateString('pt-BR') : '-' %>
                      </td>
                      <td class="text-right">
                        <div class="flex justify-end gap-2">
                          <button type="button" class="btn btn-sm btn-secondary" data-comissao-id="<%= c.id %>" onclick="verItensComissao(this.dataset.comissaoId)">
                            Itens
                          </button>
                          <% if (c.status === 'PENDENTE') { %>
                            <button type="button" class="btn btn-sm btn-success" data-id="<%= c.id %>" data-nome="<%= c.rca_nome %>" data-valor="<%= c.valor_comissao %>" onclick="abrirModalPagar(this)">
                              Pagar
                            </button>
                            <form action="/comissoes/cancelar/<%= c.id %>" method="POST" class="inline" onsubmit="return confirm('Cancelar esta comissão?')">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                              <button type="submit" class="btn btn-sm btn-danger">Cancelar</button>
                            </form>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </main>
  </div>

  <!-- Modal Gerar Comissão -->
  <div id="modalGerar" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-secondary-900">Gerar Comissão</h2>
        <button type="button" onclick="fecharModal('modalGerar')" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      
      <form action="/comissoes/gerar" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="rca_id" id="gerarRcaId">
        <input type="hidden" name="periodo_inicio" value="<%= filtros.periodo_inicio %>">
        <input type="hidden" name="periodo_fim" value="<%= filtros.periodo_fim %>">
        
        <div class="p-6">
          <div class="form-group">
            <label class="form-label">RCA</label>
            <input type="text" id="gerarRcaNome" readonly class="form-input bg-secondary-50">
          </div>
          
          <div class="bg-secondary-50 rounded-lg p-4 mt-4 space-y-3">
            <div class="flex justify-between">
              <span class="text-secondary-600">Período:</span>
              <span class="font-medium"><%= new Date(filtros.periodo_inicio).toLocaleDateString('pt-BR') %> - <%= new Date(filtros.periodo_fim).toLocaleDateString('pt-BR') %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-secondary-600">Vendas:</span>
              <span class="font-medium" id="previewVendas">Carregando...</span>
            </div>
            <div class="flex justify-between">
              <span class="text-secondary-600">Produtos Vendidos:</span>
              <span class="font-medium" id="previewProdutos">-</span>
            </div>
            <div class="flex justify-between pt-3 border-t border-secondary-200">
              <span class="text-green-700 font-semibold">Comissão RCA:</span>
              <span class="text-xl font-bold text-green-600" id="previewValor">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-violet-700 font-semibold">Comissão Rian:</span>
              <span class="text-xl font-bold text-violet-600" id="previewValorRian">-</span>
            </div>
          </div>
        </div>
        
        <div class="px-6 py-4 border-t border-secondary-200 flex justify-end gap-3">
          <button type="button" onclick="fecharModal('modalGerar')" class="btn btn-secondary">Cancelar</button>
          <button type="submit" class="btn btn-primary">Confirmar e Gerar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Pagar Comissão -->
  <div id="modalPagar" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md mx-4">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-secondary-900">Pagar Comissão</h2>
        <button type="button" onclick="fecharModal('modalPagar')" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      
      <form id="formPagar" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="p-6">
          <div class="form-group">
            <label class="form-label">RCA</label>
            <input type="text" id="pagarRcaNome" readonly class="form-input bg-secondary-50">
          </div>
          
          <div class="form-group">
            <label class="form-label">Valor a Pagar</label>
            <input type="text" id="pagarValor" readonly class="form-input bg-secondary-50 text-2xl font-bold text-green-600">
          </div>
          
          <div class="form-group">
            <label class="form-label">Data do Pagamento</label>
            <input type="date" name="data_pagamento" value="<%= new Date().toISOString().split('T')[0] %>" required class="form-input">
          </div>
          
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-3 mt-4">
            <p class="text-sm text-yellow-800">
              <i data-lucide="alert-triangle" class="w-4 h-4 inline mr-1"></i>
              Este pagamento será registrado automaticamente no Fluxo de Caixa como débito.
            </p>
          </div>
        </div>
        
        <div class="px-6 py-4 border-t border-secondary-200 flex justify-end gap-3">
          <button type="button" onclick="fecharModal('modalPagar')" class="btn btn-secondary">Cancelar</button>
          <button type="submit" class="btn btn-success">Confirmar Pagamento</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Detalhes -->
  <div id="modalDetalhes" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-4xl mx-4 max-h-[90vh] overflow-hidden flex flex-col">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-secondary-900" id="detalhesTitle">Detalhes</h2>
        <button type="button" onclick="fecharModal('modalDetalhes')" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      <div class="p-6 overflow-y-auto" id="detalhesContent">
        <p class="text-secondary-500">Carregando...</p>
      </div>
    </div>
  </div>

  <script>
    lucide.createIcons();

    // Tabs
    function showTab(tabName, btn) {
      document.querySelectorAll('.tab-content').forEach(function(tab) { tab.classList.add('hidden'); });
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('border-primary-600', 'text-primary-600');
        b.classList.add('border-transparent', 'text-secondary-500');
      });
      document.getElementById('tab-' + tabName).classList.remove('hidden');
      btn.classList.remove('border-transparent', 'text-secondary-500');
      btn.classList.add('border-primary-600', 'text-primary-600');
    }
    
    function filtrarProdutos() {
      var termo = document.getElementById('searchProduto').value.toLowerCase();
      var linhas = document.querySelectorAll('#tabelaProdutos tbody tr');
      linhas.forEach(function(linha) {
        linha.style.display = linha.textContent.toLowerCase().includes(termo) ? '' : 'none';
      });
    }
    
    function salvarComissaoProduto(produtoId) {
      var percentual = parseFloat(document.getElementById('comissao-' + produtoId).value) || 0;
      var percentualRian = parseFloat(document.getElementById('comissao-rian-' + produtoId).value) || 0;
      var fixaRca = document.getElementById('fixa-rca-' + produtoId).value;
      var fixaRian = document.getElementById('fixa-rian-' + produtoId).value;
      
      var data = { 
        percentual_comissao: percentual, 
        percentual_comissao_rian: percentualRian,
        comissao_fixa_rca: fixaRca ? parseFloat(fixaRca) : null,
        comissao_fixa_rian: fixaRian ? parseFloat(fixaRian) : null
      };
      
      fetch('/comissoes/produto/' + produtoId + '/comissao', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
        body: JSON.stringify(data)
      })
      .then(function(response) {
        if (response.ok) {
          var inputs = document.querySelectorAll('[id^="comissao-' + produtoId + '"], [id^="comissao-rian-' + produtoId + '"], [id^="fixa-rca-' + produtoId + '"], [id^="fixa-rian-' + produtoId + '"]');
          inputs.forEach(function(input) {
            input.classList.add('border-green-500', 'ring-2', 'ring-green-200');
            setTimeout(function() { input.classList.remove('border-green-500', 'ring-2', 'ring-green-200'); }, 2000);
          });
        } else { throw new Error('Erro ao salvar'); }
      })
      .catch(function() { alert('Erro ao salvar comissão'); });
    }
    
    function abrirModalGerar(btn) {
      var rcaId = btn.dataset.rcaId;
      var rcaNome = btn.dataset.rcaNome;
      
      document.getElementById('gerarRcaId').value = rcaId;
      document.getElementById('gerarRcaNome').value = rcaNome;
      document.getElementById('modalGerar').classList.remove('hidden');
      document.getElementById('modalGerar').classList.add('flex');
      
      fetch('/comissoes/api/calcular?rca_id=' + rcaId + '&periodo_inicio=<%= filtros.periodo_inicio %>&periodo_fim=<%= filtros.periodo_fim %>')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          document.getElementById('previewVendas').textContent = 'R$ ' + data.valor_vendas.toLocaleString('pt-BR', {minimumFractionDigits: 2}) + ' (' + data.qtd_vendas + ' vendas)';
          document.getElementById('previewProdutos').textContent = data.qtd_produtos + ' produtos diferentes';
          document.getElementById('previewValor').textContent = 'R$ ' + data.valor_comissao.toLocaleString('pt-BR', {minimumFractionDigits: 2});
          document.getElementById('previewValorRian').textContent = 'R$ ' + (data.valor_comissao_rian || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2});
        })
        .catch(function() { document.getElementById('previewVendas').textContent = 'Erro ao carregar'; });
        
      lucide.createIcons();
    }
    
    function abrirModalPagar(btn) {
      document.getElementById('formPagar').action = '/comissoes/pagar/' + btn.dataset.id;
      document.getElementById('pagarRcaNome').value = btn.dataset.nome;
      document.getElementById('pagarValor').value = 'R$ ' + parseFloat(btn.dataset.valor).toLocaleString('pt-BR', {minimumFractionDigits: 2});
      document.getElementById('modalPagar').classList.remove('hidden');
      document.getElementById('modalPagar').classList.add('flex');
      lucide.createIcons();
    }
    
    function verDetalhes(rcaId, rcaNome) {
      document.getElementById('detalhesTitle').textContent = 'Detalhes: ' + rcaNome;
      document.getElementById('detalhesContent').innerHTML = '<p class="text-secondary-500">Carregando...</p>';
      document.getElementById('modalDetalhes').classList.remove('hidden');
      document.getElementById('modalDetalhes').classList.add('flex');
      
      fetch('/comissoes/detalhes/' + rcaId + '?periodo_inicio=<%= filtros.periodo_inicio %>&periodo_fim=<%= filtros.periodo_fim %>')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var html = '<div class="bg-secondary-50 rounded-lg p-4 mb-4">' +
            '<div class="flex justify-between mb-2"><span class="text-secondary-600">Total Vendido:</span><span class="font-semibold">R$ ' + data.totais.valor_vendido.toLocaleString('pt-BR', {minimumFractionDigits: 2}) + '</span></div>' +
            '<div class="flex justify-between mb-2"><span class="text-green-600">Comissão RCA:</span><span class="font-bold text-green-600">R$ ' + data.totais.valor_comissao.toLocaleString('pt-BR', {minimumFractionDigits: 2}) + '</span></div>' +
            '<div class="flex justify-between"><span class="text-violet-600">Comissão Rian:</span><span class="font-bold text-violet-600">R$ ' + (data.totais.valor_comissao_rian || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) + '</span></div>' +
          '</div>' +
          '<div class="table-container"><table class="table text-sm"><thead><tr>' +
            '<th>Produto</th><th class="text-center">Qtd</th><th class="text-right">Valor</th><th class="text-center">% RCA</th><th class="text-right">Com. RCA</th><th class="text-right">Com. Rian</th>' +
          '</tr></thead><tbody>';
          
          data.vendas.forEach(function(v) {
            var tipoRca = v.comissao_fixa_rca ? 'R$ ' + v.comissao_fixa_rca.toFixed(2) + '/un' : v.percentual_comissao + '%';
            html += '<tr>' +
              '<td><span class="font-medium">' + v.codigo + '</span> - ' + v.descricao + '</td>' +
              '<td class="text-center">' + v.quantidade_vendida + '</td>' +
              '<td class="text-right">R$ ' + v.valor_vendido.toLocaleString('pt-BR', {minimumFractionDigits: 2}) + '</td>' +
              '<td class="text-center">' + tipoRca + '</td>' +
              '<td class="text-right font-semibold text-green-600">R$ ' + v.valor_comissao.toLocaleString('pt-BR', {minimumFractionDigits: 2}) + '</td>' +
              '<td class="text-right font-semibold text-violet-600">R$ ' + (v.valor_comissao_rian || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) + '</td>' +
            '</tr>';
          });
          
          html += '</tbody></table></div>';
          document.getElementById('detalhesContent').innerHTML = html;
        })
        .catch(function() { document.getElementById('detalhesContent').innerHTML = '<p class="text-red-600">Erro ao carregar detalhes</p>'; });
    }
    
    function verItensComissao(comissaoId) {
      document.getElementById('detalhesTitle').textContent = 'Itens da Comissão';
      document.getElementById('detalhesContent').innerHTML = '<p class="text-secondary-500">Carregando...</p>';
      document.getElementById('modalDetalhes').classList.remove('hidden');
      document.getElementById('modalDetalhes').classList.add('flex');
      
      fetch('/comissoes/itens/' + comissaoId)
        .then(function(r) { return r.json(); })
        .then(function(itens) {
          var html = '<div class="table-container"><table class="table text-sm"><thead><tr>' +
            '<th>Produto</th><th class="text-center">Qtd</th><th class="text-right">Valor</th><th class="text-center">%</th><th class="text-right">Com. RCA</th><th class="text-right">Com. Rian</th>' +
          '</tr></thead><tbody>';
          
          itens.forEach(function(item) {
            html += '<tr>' +
              '<td><span class="font-medium">' + item.codigo + '</span> - ' + item.descricao + '</td>' +
              '<td class="text-center">' + parseFloat(item.quantidade_vendida).toFixed(0) + '</td>' +
              '<td class="text-right">R$ ' + parseFloat(item.valor_vendido).toLocaleString('pt-BR', {minimumFractionDigits: 2}) + '</td>' +
              '<td class="text-center">' + item.percentual_aplicado + '%</td>' +
              '<td class="text-right font-semibold text-green-600">R$ ' + parseFloat(item.valor_comissao_item).toLocaleString('pt-BR', {minimumFractionDigits: 2}) + '</td>' +
              '<td class="text-right font-semibold text-violet-600">R$ ' + parseFloat(item.valor_comissao_rian_item || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) + '</td>' +
            '</tr>';
          });
          
          html += '</tbody></table></div>';
          document.getElementById('detalhesContent').innerHTML = html;
        })
        .catch(function() { document.getElementById('detalhesContent').innerHTML = '<p class="text-red-600">Erro ao carregar itens</p>'; });
    }
    
    function fecharModal(modalId) {
      document.getElementById(modalId).classList.add('hidden');
      document.getElementById(modalId).classList.remove('flex');
    }
    
    document.querySelectorAll('#modalGerar, #modalPagar, #modalDetalhes').forEach(function(modal) {
      modal.addEventListener('click', function(e) { if (e.target === modal) fecharModal(modal.id); });
    });
  </script>
</body>
</html>
