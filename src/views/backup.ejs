<!-- views/backup.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Backup | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'backup' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container">
      
      <!-- Page Header -->
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-secondary-900">Backup do Sistema</h1>
        <p class="mt-1 text-secondary-500">Faça backup completo dos seus dados</p>
      </div>

      <!-- Alert Messages -->
      <% if (locals.message) { %>
        <div class="mb-6 p-4 rounded-lg flex items-start gap-3 <%= message.type === 'error' ? 'bg-red-50 border border-red-200 text-red-800' : message.type === 'info' ? 'bg-blue-50 border border-blue-200 text-blue-800' : 'bg-green-50 border border-green-200 text-green-800' %>">
          <% if (message.type === 'error') { %>
            <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
          <% } else if (message.type === 'info') { %>
            <i data-lucide="info" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
          <% } else { %>
            <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
          <% } %>
          <span><%= message.text %></span>
        </div>
      <% } %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Main Card - Gerar Backup -->
        <div class="lg:col-span-2">
          <div class="card">
            <div class="card-body">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-xl bg-primary-100 flex items-center justify-center flex-shrink-0">
                  <i data-lucide="hard-drive-download" class="w-7 h-7 text-primary-600"></i>
                </div>
                <div class="flex-1">
                  <h2 class="text-xl font-semibold text-secondary-900 mb-2">Backup Completo</h2>
                  <p class="text-secondary-600 mb-6">
                    Gere um arquivo SQL com todos os dados do sistema. O backup inclui estrutura das tabelas, 
                    dados, sequências, constraints e índices.
                  </p>
                  
                  <form action="/backup/gerar" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-primary btn-lg" id="btnBackup">
                      <i data-lucide="download" class="w-5 h-5 mr-2"></i>
                      Gerar Backup Completo
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>

          <!-- O que está incluído -->
          <div class="card mt-6">
            <div class="card-header">
              <h3 class="text-lg font-semibold text-secondary-900 flex items-center gap-2">
                <i data-lucide="check-circle" class="w-5 h-5 text-green-600"></i>
                O que está incluído no backup
              </h3>
            </div>
            <div class="card-body">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="flex items-start gap-3 p-3 rounded-lg bg-secondary-50">
                  <i data-lucide="table" class="w-5 h-5 text-primary-600 mt-0.5"></i>
                  <div>
                    <p class="font-medium text-secondary-900">Estrutura das Tabelas</p>
                    <p class="text-sm text-secondary-500">CREATE TABLE completo</p>
                  </div>
                </div>
                
                <div class="flex items-start gap-3 p-3 rounded-lg bg-secondary-50">
                  <i data-lucide="database" class="w-5 h-5 text-primary-600 mt-0.5"></i>
                  <div>
                    <p class="font-medium text-secondary-900">Todos os Dados</p>
                    <p class="text-sm text-secondary-500">INSERT de todas as tabelas</p>
                  </div>
                </div>
                
                <div class="flex items-start gap-3 p-3 rounded-lg bg-secondary-50">
                  <i data-lucide="users" class="w-5 h-5 text-primary-600 mt-0.5"></i>
                  <div>
                    <p class="font-medium text-secondary-900">Usuários do Sistema</p>
                    <p class="text-sm text-secondary-500">Credenciais e permissões</p>
                  </div>
                </div>
                
                <div class="flex items-start gap-3 p-3 rounded-lg bg-secondary-50">
                  <i data-lucide="hash" class="w-5 h-5 text-primary-600 mt-0.5"></i>
                  <div>
                    <p class="font-medium text-secondary-900">Sequências</p>
                    <p class="text-sm text-secondary-500">Contadores de ID</p>
                  </div>
                </div>
                
                <div class="flex items-start gap-3 p-3 rounded-lg bg-secondary-50">
                  <i data-lucide="link" class="w-5 h-5 text-primary-600 mt-0.5"></i>
                  <div>
                    <p class="font-medium text-secondary-900">Constraints</p>
                    <p class="text-sm text-secondary-500">Chaves primárias e estrangeiras</p>
                  </div>
                </div>
                
                <div class="flex items-start gap-3 p-3 rounded-lg bg-secondary-50">
                  <i data-lucide="zap" class="w-5 h-5 text-primary-600 mt-0.5"></i>
                  <div>
                    <p class="font-medium text-secondary-900">Índices</p>
                    <p class="text-sm text-secondary-500">Performance otimizada</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar - Instruções -->
        <div class="lg:col-span-1">
          <!-- Como restaurar -->
          <div class="card">
            <div class="card-header bg-yellow-50 border-b border-yellow-200">
              <h3 class="text-base font-semibold text-yellow-800 flex items-center gap-2">
                <i data-lucide="alert-triangle" class="w-5 h-5"></i>
                Como Restaurar
              </h3>
            </div>
            <div class="card-body">
              <ol class="space-y-4">
                <li class="flex gap-3">
                  <span class="w-6 h-6 rounded-full bg-yellow-100 text-yellow-700 flex items-center justify-center text-sm font-semibold flex-shrink-0">1</span>
                  <div>
                    <p class="text-sm text-secondary-700">Acesse o console do PostgreSQL</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <span class="w-6 h-6 rounded-full bg-yellow-100 text-yellow-700 flex items-center justify-center text-sm font-semibold flex-shrink-0">2</span>
                  <div>
                    <p class="text-sm text-secondary-700">Execute o comando:</p>
                    <code class="block mt-2 p-2 bg-secondary-100 rounded text-xs font-mono text-secondary-800 break-all">
                      psql -U usuario -d banco &lt; backup.sql
                    </code>
                  </div>
                </li>
                <li class="flex gap-3">
                  <span class="w-6 h-6 rounded-full bg-yellow-100 text-yellow-700 flex items-center justify-center text-sm font-semibold flex-shrink-0">3</span>
                  <div>
                    <p class="text-sm text-secondary-700">Ou use o pgAdmin para importar o arquivo SQL</p>
                  </div>
                </li>
              </ol>
            </div>
          </div>

          <!-- Dicas -->
          <div class="card mt-6">
            <div class="card-header">
              <h3 class="text-base font-semibold text-secondary-900 flex items-center gap-2">
                <i data-lucide="lightbulb" class="w-5 h-5 text-yellow-500"></i>
                Boas Práticas
              </h3>
            </div>
            <div class="card-body">
              <ul class="space-y-3 text-sm text-secondary-600">
                <li class="flex items-start gap-2">
                  <i data-lucide="check" class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0"></i>
                  <span>Faça backup regularmente (diário ou semanal)</span>
                </li>
                <li class="flex items-start gap-2">
                  <i data-lucide="check" class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0"></i>
                  <span>Armazene em local seguro (nuvem ou HD externo)</span>
                </li>
                <li class="flex items-start gap-2">
                  <i data-lucide="check" class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0"></i>
                  <span>Teste a restauração periodicamente</span>
                </li>
                <li class="flex items-start gap-2">
                  <i data-lucide="check" class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0"></i>
                  <span>Mantenha múltiplas versões</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>

  <script>
    // Inicializa ícones
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
    });

    // Loading state no botão
    document.querySelector('form[action="/backup/gerar"]').addEventListener('submit', function() {
      var btn = document.getElementById('btnBackup');
      btn.disabled = true;
      btn.innerHTML = '<svg class="w-5 h-5 mr-2 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" stroke-dasharray="32" stroke-dashoffset="32"><animate attributeName="stroke-dashoffset" values="32;0" dur="1s" repeatCount="indefinite"/></circle></svg> Gerando backup...';
    });
  </script>
</body>
</html>
