<!-- views/contas-a-pagar.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contas a Pagar | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'contas-a-pagar' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container" style="max-width: 1400px;">
      
      <!-- Page Header -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-secondary-900 flex items-center gap-3">
            <i data-lucide="file-text" class="w-8 h-8 text-primary-600"></i>
            Contas a Pagar
          </h1>
          <p class="mt-1 text-secondary-500">Gerencie suas despesas e obrigações futuras</p>
        </div>
        <button type="button" onclick="abrirModalConta()" class="btn btn-primary">
          <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
          Nova Conta
        </button>
      </div>

      <!-- Info Banner -->
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6 flex items-start gap-3">
        <i data-lucide="info" class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5"></i>
        <p class="text-sm text-blue-800">
          <strong>Informação importante:</strong> Esta tela exibe as contas a pagar pendentes e já quitadas. 
          Use os filtros para visualizar por período específico.
        </p>
      </div>

      <!-- Filtros -->
      <div class="card mb-6">
        <div class="card-header">
          <h2 class="text-base font-semibold text-secondary-900 flex items-center gap-2">
            <i data-lucide="filter" class="w-5 h-5 text-secondary-500"></i>
            Filtros de Período
          </h2>
        </div>
        <div class="card-body py-4">
          <form method="GET" action="/contas-a-pagar" class="flex flex-wrap items-end gap-4">
            <div class="min-w-[160px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block flex items-center gap-1">
                <i data-lucide="calendar" class="w-3 h-3"></i>
                Data Inicial
              </label>
              <input type="date" name="data_inicio" class="form-input" value="<%= locals.filtros ? filtros.data_inicio : '' %>">
            </div>
            
            <div class="min-w-[160px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block flex items-center gap-1">
                <i data-lucide="calendar" class="w-3 h-3"></i>
                Data Final
              </label>
              <input type="date" name="data_fim" class="form-input" value="<%= locals.filtros ? filtros.data_fim : '' %>">
            </div>
            
            <div class="flex gap-2">
              <button type="submit" class="btn btn-primary">
                <i data-lucide="search" class="w-4 h-4 mr-1"></i>
                Filtrar
              </button>
              
              <a href="/contas-a-pagar" class="btn btn-secondary">
                <i data-lucide="refresh-cw" class="w-4 h-4 mr-1"></i>
                Limpar
              </a>
            </div>
          </form>
        </div>
      </div>

      <!-- Tabela -->
      <div class="card">
        <div class="card-header flex items-center justify-between">
          <h2 class="text-lg font-semibold text-secondary-900 flex items-center gap-2">
            <i data-lucide="layout-list" class="w-5 h-5 text-primary-600"></i>
            Contas a Pagar
          </h2>
          <span class="text-sm text-secondary-500"><%= contas ? contas.length : 0 %> conta(s)</span>
        </div>

        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>Descrição</th>
                <th>Fornecedor</th>
                <th>Vencimento</th>
                <th class="text-right">Valor</th>
                <th class="text-center">Status</th>
                <th>Categoria</th>
                <th class="text-right">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (contas && contas.length > 0) { %>
                <% contas.forEach(function(conta) { %>
                  <% 
                    var dataVencimento = new Date(conta.data_vencimento);
                    var hoje = new Date();
                    var isVencida = dataVencimento < hoje && conta.status === 'Pendente';
                  %>
                  <tr>
                    <td>
                      <span class="font-medium text-secondary-900"><%= conta.descricao %></span>
                    </td>
                    <td class="text-secondary-600">
                      <%= conta.fornecedor_nome || '-' %>
                    </td>
                    <td>
                      <span class="font-mono text-sm <%= isVencida ? 'text-red-600 font-semibold' : 'text-secondary-600' %>">
                        <%= dataVencimento.toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %>
                      </span>
                      <% if (isVencida) { %>
                        <span class="block text-xs text-red-500 font-medium">Vencida</span>
                      <% } %>
                    </td>
                    <td class="text-right">
                      <span class="font-semibold font-mono">
                        R$ <%= parseFloat(conta.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                      </span>
                    </td>
                    <td class="text-center">
                      <% if (conta.status === 'Pago') { %>
                        <span class="badge badge-success">
                          <i data-lucide="check" class="w-3 h-3 mr-1"></i>
                          Pago
                        </span>
                      <% } else { %>
                        <span class="badge badge-warning">
                          <i data-lucide="clock" class="w-3 h-3 mr-1"></i>
                          Pendente
                        </span>
                      <% } %>
                    </td>
                    <td class="text-secondary-600">
                      <%= conta.categoria_nome || 'Sem categoria' %>
                    </td>
                    <td class="text-right">
                      <div class="flex justify-end gap-2">
                        <% if (conta.status === 'Pendente') { %>
                          <button type="button"
                                  class="btn btn-sm btn-success btn-pagar-conta"
                                  data-conta-id="<%= conta.id %>"
                                  data-descricao="<%= conta.descricao %>"
                                  data-fornecedor="<%= conta.fornecedor_nome || 'Não informado' %>"
                                  data-valor="<%= conta.valor %>"
                                  title="Registrar pagamento">
                            <i data-lucide="dollar-sign" class="w-3 h-3 mr-1"></i>
                            Pagar
                          </button>

                          <form action="/contas-a-pagar/delete/<%= conta.id %>" method="POST" class="inline" onsubmit="return confirm('Confirma a exclusão desta conta?');">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-secondary text-danger-600" title="Excluir">
                              <i data-lucide="trash-2" class="w-3 h-3 mr-1"></i>
                              Excluir
                            </button>
                          </form>
                        <% } else { %>
                          <form action="/contas-a-pagar/estornar/<%= conta.id %>" method="POST" class="inline" onsubmit="return confirm('Confirma o estorno deste pagamento?');">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-secondary" title="Estornar">
                              <i data-lucide="undo-2" class="w-3 h-3 mr-1"></i>
                              Estornar
                            </button>
                          </form>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="7">
                    <div class="py-12 text-center">
                      <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mx-auto mb-4">
                        <i data-lucide="file-x" class="w-8 h-8 text-secondary-400"></i>
                      </div>
                      <h3 class="text-lg font-medium text-secondary-900 mb-2">Nenhuma conta encontrada</h3>
                      <p class="text-secondary-500">Cadastre sua primeira conta a pagar</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
            <tfoot>
              <tr class="bg-secondary-50 font-semibold">
                <td colspan="3" class="text-right">Total do Período:</td>
                <td class="text-right font-mono">
                  R$ <%= (totalValor || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
                </td>
                <td colspan="3"></td>
              </tr>
              <tr class="bg-yellow-50 font-semibold text-yellow-700">
                <td colspan="3" class="text-right">Total Pendente:</td>
                <td class="text-right font-mono">
                  R$ <%= (totalPendente || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
                </td>
                <td colspan="3"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>

    </main>
  </div>

  <!-- Modal Nova Conta -->
  <div id="modalNovaConta" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-xl mx-4 max-h-[90vh] overflow-y-auto">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between sticky top-0 bg-white">
        <h2 class="text-lg font-bold text-secondary-900 flex items-center gap-2">
          <i data-lucide="plus-circle" class="w-5 h-5 text-primary-600"></i>
          Nova Conta a Pagar
        </h2>
        <button type="button" onclick="fecharModalConta()" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      
      <form action="/contas-a-pagar" method="POST" class="p-6">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Descrição -->
          <div class="form-group md:col-span-2">
            <label for="descricao" class="form-label">
              <i data-lucide="file-text" class="w-4 h-4 mr-1"></i>
              Descrição *
            </label>
            <input type="text" id="descricao" name="descricao" class="form-input" placeholder="Descreva a despesa..." required>
          </div>
          
          <!-- Fornecedor -->
          <div class="form-group">
            <label for="fornecedor_id" class="form-label">
              <i data-lucide="building" class="w-4 h-4 mr-1"></i>
              Fornecedor
            </label>
            <select id="fornecedor_id" name="fornecedor_id" class="form-select">
              <option value="">Selecione...</option>
              <% fornecedores.forEach(function(fornecedor) { %>
                <option value="<%= fornecedor.id %>"><%= fornecedor.nome %></option>
              <% }); %>
            </select>
            <a href="/fornecedores" target="_blank" class="text-xs text-primary-600 hover:underline mt-1 inline-block">
              Cadastrar novo fornecedor
            </a>
          </div>

          <!-- Valor -->
          <div class="form-group">
            <label for="valor" class="form-label">
              <i data-lucide="dollar-sign" class="w-4 h-4 mr-1"></i>
              Valor (R$) *
            </label>
            <input type="number" id="valor" name="valor" class="form-input" step="0.01" min="0.01" placeholder="0,00" required>
          </div>
          
          <!-- Data Vencimento -->
          <div class="form-group">
            <label for="data_vencimento" class="form-label">
              <i data-lucide="calendar" class="w-4 h-4 mr-1"></i>
              Data de Vencimento *
            </label>
            <input type="date" id="data_vencimento" name="data_vencimento" class="form-input" required>
          </div>

          <!-- Categoria -->
          <div class="form-group">
            <label for="categoria_id" class="form-label">
              <i data-lucide="tag" class="w-4 h-4 mr-1"></i>
              Categoria *
            </label>
            <select id="categoria_id" name="categoria_id" class="form-select" required>
              <option value="">Selecione...</option>
              <% categorias.forEach(function(categoria) { %>
                <option value="<%= categoria.id %>"><%= categoria.nome %></option>
              <% }); %>
            </select>
          </div>
        </div>
        
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-secondary-200">
          <button type="button" onclick="fecharModalConta()" class="btn btn-secondary">
            Cancelar
          </button>
          <button type="submit" class="btn btn-primary">
            <i data-lucide="save" class="w-4 h-4 mr-2"></i>
            Criar Conta
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Pagamento -->
  <div id="modalPagamento" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between">
        <h2 class="text-lg font-bold text-secondary-900 flex items-center gap-2">
          <i data-lucide="credit-card" class="w-5 h-5 text-primary-600"></i>
          Registrar Pagamento
        </h2>
        <button type="button" onclick="fecharModalPagamento()" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      
      <form id="formPagamento" method="POST" class="p-6">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <!-- Info do Pagamento -->
        <div class="bg-secondary-50 rounded-lg p-4 mb-6 space-y-3">
          <div>
            <label class="text-xs font-semibold text-secondary-500 uppercase">Descrição</label>
            <p class="font-medium text-secondary-900" id="pagamentoDescricao">-</p>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-xs font-semibold text-secondary-500 uppercase">Fornecedor</label>
              <p class="font-medium text-secondary-900" id="pagamentoFornecedor">-</p>
            </div>
            <div>
              <label class="text-xs font-semibold text-secondary-500 uppercase">Valor</label>
              <p class="text-xl font-bold text-green-600" id="pagamentoValor">R$ 0,00</p>
            </div>
          </div>
        </div>

        <!-- Data Pagamento -->
        <div class="form-group">
          <label for="dataPagamento" class="form-label">
            <i data-lucide="calendar" class="w-4 h-4 mr-1"></i>
            Data do Pagamento *
          </label>
          <input type="date" id="dataPagamento" name="data_pagamento" class="form-input" required max="<%= new Date().toISOString().split('T')[0] %>">
          <p class="text-xs text-yellow-600 mt-1 flex items-center gap-1">
            <i data-lucide="alert-triangle" class="w-3 h-3"></i>
            A data não pode ser futura
          </p>
        </div>
        
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-secondary-200">
          <button type="button" onclick="fecharModalPagamento()" class="btn btn-secondary">
            Cancelar
          </button>
          <button type="submit" class="btn btn-success">
            <i data-lucide="check" class="w-4 h-4 mr-2"></i>
            Confirmar Pagamento
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Inicializa ícones
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
      
      // Event delegation para botões de pagar
      document.addEventListener('click', function(e) {
        var btnPagar = e.target.closest('.btn-pagar-conta');
        if (!btnPagar) return;
        
        var contaId = btnPagar.dataset.contaId;
        var descricao = btnPagar.dataset.descricao;
        var fornecedor = btnPagar.dataset.fornecedor;
        var valor = btnPagar.dataset.valor;
        
        abrirModalPagamento(contaId, descricao, fornecedor, valor);
      });
      
      // Fechar modais ao clicar fora
      document.querySelectorAll('#modalNovaConta, #modalPagamento').forEach(function(modal) {
        modal.addEventListener('click', function(e) {
          if (e.target === this) {
            if (this.id === 'modalNovaConta') fecharModalConta();
            else fecharModalPagamento();
          }
        });
      });
      
      // Fechar com ESC
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          fecharModalConta();
          fecharModalPagamento();
        }
      });
      
      // Validação do formulário de pagamento
      document.getElementById('formPagamento').addEventListener('submit', function(e) {
        var dataPagamento = document.getElementById('dataPagamento').value;
        var hoje = new Date().toISOString().split('T')[0];
        
        if (!dataPagamento) {
          e.preventDefault();
          alert('Por favor, selecione a data do pagamento.');
          return;
        }
        
        if (dataPagamento > hoje) {
          e.preventDefault();
          alert('A data de pagamento não pode ser no futuro.');
          return;
        }
        
        if (!confirm('Confirma o pagamento desta conta na data selecionada?')) {
          e.preventDefault();
        }
      });
    });

    // Modal Nova Conta
    function abrirModalConta() {
      var modal = document.getElementById('modalNovaConta');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      lucide.createIcons();
    }

    function fecharModalConta() {
      var modal = document.getElementById('modalNovaConta');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }

    // Modal Pagamento
    function abrirModalPagamento(contaId, descricao, fornecedor, valor) {
      document.getElementById('pagamentoDescricao').textContent = descricao;
      document.getElementById('pagamentoFornecedor').textContent = fornecedor;
      document.getElementById('pagamentoValor').textContent = 'R$ ' + parseFloat(valor).toLocaleString('pt-BR', {minimumFractionDigits: 2});
      
      document.getElementById('formPagamento').action = '/contas-a-pagar/pagar/' + contaId;
      
      var hoje = new Date().toISOString().split('T')[0];
      document.getElementById('dataPagamento').value = hoje;
      
      var modal = document.getElementById('modalPagamento');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      
      lucide.createIcons();
      
      setTimeout(function() {
        document.getElementById('dataPagamento').focus();
      }, 100);
    }

    function fecharModalPagamento() {
      var modal = document.getElementById('modalPagamento');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }
  </script>
</body>
</html>
