<!-- views/movimentacoes.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Movimentações | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'movimentacoes' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container" style="max-width: 1400px;">
      
      <!-- Page Header -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-secondary-900">Movimentações de Estoque</h1>
          <p class="mt-1 text-secondary-500">Gerencie entradas e saídas de produtos</p>
        </div>
        <button type="button" onclick="openCreateModal()" class="btn btn-primary">
          <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
          Nova Movimentação
        </button>
      </div>

      <!-- Filtros -->
      <div class="card mb-6">
        <div class="card-body py-4">
          <div class="flex flex-wrap gap-4 items-end">
            <div class="flex-1 min-w-[150px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block">Tipo</label>
              <select id="filtroTipo" class="form-select" onchange="applyFilters()">
                <option value="">Todos</option>
                <option value="ENTRADA" <%= filtros.tipo === 'ENTRADA' ? 'selected' : '' %>>Entrada</option>
                <option value="SAIDA" <%= filtros.tipo === 'SAIDA' ? 'selected' : '' %>>Saída</option>
              </select>
            </div>
            
            <div class="flex-1 min-w-[200px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block">Produto</label>
              <select id="filtroProduto" class="form-select" onchange="applyFilters()">
                <option value="">Todos os produtos</option>
                <% produtos.forEach(function(produto) { %>
                  <option value="<%= produto.id %>" <%= filtros.produto_id == produto.id ? 'selected' : '' %>>
                    <%= produto.codigo %> - <%= produto.descricao %>
                  </option>
                <% }); %>
              </select>
            </div>
            
            <div class="min-w-[140px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block">Data Inicial</label>
              <input type="date" id="filtroDataInicial" class="form-input" value="<%= filtros.data_inicial || '' %>" onchange="applyFilters()">
            </div>
            
            <div class="min-w-[140px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block">Data Final</label>
              <input type="date" id="filtroDataFinal" class="form-input" value="<%= filtros.data_fim || '' %>" onchange="applyFilters()">
            </div>

            <button type="button" class="btn btn-secondary" onclick="clearFilters()">
              <i data-lucide="x" class="w-4 h-4 mr-1"></i>
              Limpar
            </button>
          </div>
        </div>
      </div>

      <!-- KPIs Dashboard -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Entradas do Mês -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-t-4 border-green-500 hover:shadow-lg transition-shadow">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-green-100 flex items-center justify-center">
              <i data-lucide="arrow-down-circle" class="w-7 h-7 text-green-600"></i>
            </div>
            <div>
              <p class="text-xs font-medium text-secondary-500">Entradas do Mês</p>
              <p class="text-3xl font-bold text-secondary-900"><%= metrics.entradas_mes %></p>
              <p class="text-xs text-secondary-400">movimentações</p>
            </div>
          </div>
        </div>

        <!-- Saídas do Mês -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-t-4 border-red-500 hover:shadow-lg transition-shadow">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-red-100 flex items-center justify-center">
              <i data-lucide="arrow-up-circle" class="w-7 h-7 text-red-600"></i>
            </div>
            <div>
              <p class="text-xs font-medium text-secondary-500">Saídas do Mês</p>
              <p class="text-3xl font-bold text-secondary-900"><%= metrics.saidas_mes %></p>
              <p class="text-xs text-secondary-400">movimentações</p>
            </div>
          </div>
        </div>

        <!-- Total Movimentações -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-t-4 border-blue-500 hover:shadow-lg transition-shadow">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-blue-100 flex items-center justify-center">
              <i data-lucide="repeat" class="w-7 h-7 text-blue-600"></i>
            </div>
            <div>
              <p class="text-xs font-medium text-secondary-500">Total de Movimentações</p>
              <p class="text-3xl font-bold text-secondary-900"><%= metrics.total_movimentacoes %></p>
              <p class="text-xs text-secondary-400">registros</p>
            </div>
          </div>
        </div>

        <!-- Valor Total -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-t-4 border-yellow-500 hover:shadow-lg transition-shadow">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-xl bg-yellow-100 flex items-center justify-center">
              <i data-lucide="dollar-sign" class="w-7 h-7 text-yellow-600"></i>
            </div>
            <div>
              <p class="text-xs font-medium text-secondary-500">Valor Total</p>
              <p class="text-2xl font-bold text-secondary-900">R$ <%= metrics.valor_total.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></p>
              <p class="text-xs text-secondary-400">movimentado</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Tabela -->
      <div class="card">
        <div class="table-container">
          <table class="table" id="tabelaMovimentacoes">
            <thead>
              <tr>
                <th>Data</th>
                <th>Tipo</th>
                <th>Produto</th>
                <th class="text-right">Qtd</th>
                <th class="text-right">Valor Unit.</th>
                <th class="text-right">Valor Total</th>
                <th>Origem/Destino</th>
                <th class="text-right">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (movimentacoes.length > 0) { %>
                <% movimentacoes.forEach(function(mov) { %>
                  <tr>
                    <td class="font-mono text-sm text-secondary-600">
                      <%= new Date(mov.created_at).toLocaleDateString('pt-BR') %>
                    </td>
                    <td>
                      <span class="badge <%= mov.tipo === 'ENTRADA' ? 'badge-success' : 'badge-warning' %>">
                        <i data-lucide="<%= mov.tipo === 'ENTRADA' ? 'arrow-down' : 'arrow-up' %>" class="w-3 h-3 mr-1"></i>
                        <%= mov.tipo %>
                      </span>
                    </td>
                    <td>
                      <div>
                        <p class="font-medium text-secondary-900"><%= mov.produto_codigo %></p>
                        <p class="text-xs text-secondary-500"><%= mov.produto_descricao %></p>
                      </div>
                    </td>
                    <td class="text-right font-medium"><%= parseFloat(mov.quantidade) % 1 === 0 ? parseFloat(mov.quantidade) : parseFloat(mov.quantidade).toFixed(1) %></td>
                    <td class="text-right text-secondary-600">
                      <%= mov.preco_unitario ? 'R$ ' + parseFloat(mov.preco_unitario).toFixed(2) : '-' %>
                    </td>
                    <td class="text-right font-semibold text-green-600">
                      R$ <%= parseFloat(mov.valor_total_calc || 0).toFixed(2) %>
                    </td>
                    <td class="text-secondary-600">
                      <% if (mov.tipo === 'ENTRADA' && mov.fornecedor_nome) { %>
                        <%= mov.fornecedor_nome %>
                      <% } else if (mov.tipo === 'SAIDA' && mov.cliente_nome) { %>
                        <%= mov.cliente_nome %>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td class="text-right">
                      <div class="flex justify-end gap-1">
                        <button type="button" class="btn-icon" data-id="<%= mov.id %>" data-action="view" title="Visualizar">
                          <i data-lucide="eye" class="w-4 h-4"></i>
                        </button>
                        <button type="button" class="btn-icon" data-id="<%= mov.id %>" data-action="edit" title="Editar">
                          <i data-lucide="pencil" class="w-4 h-4"></i>
                        </button>
                        <button type="button" class="btn-icon text-danger-600" data-id="<%= mov.id %>" data-action="delete" title="Excluir">
                          <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="8">
                    <div class="py-12 text-center">
                      <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mx-auto mb-4">
                        <i data-lucide="clipboard-list" class="w-8 h-8 text-secondary-400"></i>
                      </div>
                      <h3 class="text-lg font-medium text-secondary-900 mb-2">Nenhuma movimentação encontrada</h3>
                      <p class="text-secondary-500">Crie sua primeira movimentação ou ajuste os filtros</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
  </div>

  <!-- Modal Criar/Editar -->
  <div id="modalForm" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-2xl mx-4 max-h-[90vh] overflow-y-auto">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between sticky top-0 bg-white">
        <h2 id="modalTitle" class="text-lg font-bold text-secondary-900">Nova Movimentação</h2>
        <button type="button" onclick="closeModal('modalForm')" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>

      <form id="movimentacaoForm" method="POST" class="p-6">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Tipo -->
          <div class="form-group">
            <label for="tipo" class="form-label">Tipo *</label>
            <select id="tipo" name="tipo" required class="form-select" onchange="updateFormFields()">
              <option value="">Selecione</option>
              <option value="ENTRADA">Entrada</option>
              <option value="SAIDA">Saída</option>
            </select>
          </div>

          <!-- Produto -->
          <div class="form-group">
            <label for="produto_id" class="form-label">Produto *</label>
            <select id="produto_id" name="produto_id" required class="form-select">
              <option value="">Selecione</option>
              <% produtos.forEach(function(produto) { %>
                <option value="<%= produto.id %>"><%= produto.codigo %> - <%= produto.descricao %></option>
              <% }); %>
            </select>
          </div>

          <!-- Quantidade -->
          <div class="form-group">
            <label for="quantidade" class="form-label">Quantidade *</label>
            <input type="number" id="quantidade" name="quantidade" step="0.001" required class="form-input" oninput="calcularValorTotal()">
          </div>

          <!-- Preço Unitário -->
          <div class="form-group">
            <label for="preco_unitario" class="form-label">Preço Unitário</label>
            <input type="number" id="preco_unitario" name="preco_unitario" step="0.01" class="form-input" oninput="calcularValorTotal()">
          </div>

          <!-- Valor Total (calculado) -->
          <div class="form-group">
            <label for="valor_total_display" class="form-label">Valor Total (calculado)</label>
            <input type="text" id="valor_total_display" disabled class="form-input bg-secondary-50 font-semibold text-primary-700">
            <input type="hidden" id="valor_total" name="valor_total">
          </div>

          <!-- Fornecedor (condicional) -->
          <div class="form-group" id="fornecedor_group" style="display: none;">
            <label for="fornecedor_id" class="form-label">Fornecedor</label>
            <select id="fornecedor_id" name="fornecedor_id" class="form-select">
              <option value="">Selecione</option>
              <% fornecedores.forEach(function(f) { %>
                <option value="<%= f.id %>"><%= f.nome %></option>
              <% }); %>
            </select>
          </div>

          <!-- Cliente (condicional) -->
          <div class="form-group" id="cliente_group" style="display: none;">
            <label for="cliente_nome" class="form-label">Cliente</label>
            <input type="text" id="cliente_nome" name="cliente_nome" class="form-input">
          </div>

          <!-- RCA -->
          <div class="form-group">
            <label for="rca" class="form-label">RCA</label>
            <select id="rca" name="rca" class="form-select">
              <option value="">Selecione</option>
              <% rcas.forEach(function(r) { %>
                <option value="<%= r.nome %>"><%= r.nome %></option>
              <% }); %>
            </select>
          </div>

          <!-- Documento -->
          <div class="form-group">
            <label for="documento" class="form-label">Documento</label>
            <input type="text" id="documento" name="documento" class="form-input" placeholder="NF, Pedido, etc.">
          </div>

          <!-- Observação -->
          <div class="form-group md:col-span-2">
            <label for="observacao" class="form-label">Observações</label>
            <textarea id="observacao" name="observacao" rows="3" class="form-input"></textarea>
          </div>
        </div>

        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-secondary-200">
          <button type="button" onclick="closeModal('modalForm')" class="btn btn-secondary">Cancelar</button>
          <button type="submit" class="btn btn-primary">
            <i data-lucide="save" class="w-4 h-4 mr-2"></i>
            Salvar
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Visualizar -->
  <div id="modalView" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-2xl mx-4">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between">
        <h2 class="text-lg font-bold text-secondary-900">Detalhes da Movimentação</h2>
        <button type="button" onclick="closeModal('modalView')" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>

      <div class="p-6" id="viewContent">
        <div class="text-center py-8 text-secondary-500">Carregando...</div>
      </div>

      <div class="px-6 py-4 border-t border-secondary-200 flex justify-end">
        <button type="button" onclick="closeModal('modalView')" class="btn btn-secondary">Fechar</button>
      </div>
    </div>
  </div>

  <!-- Form oculto para delete com CSRF -->
  <form id="deleteForm" method="POST" style="display: none;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  </form>

  <style>
    .btn-icon {
      padding: 6px;
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
      color: #64748b;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .btn-icon:hover {
      background: #f1f5f9;
      border-color: #cbd5e1;
      transform: translateY(-1px);
    }
    .btn-icon.text-danger-600:hover {
      background: #fef2f2;
      border-color: #fecaca;
      color: #dc2626;
    }
  </style>

  <script>
    // CSRF Token global
    var csrfToken = '<%= csrfToken %>';
    
    // Inicializa ícones
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
      
      // Event delegation para botões de ação na tabela
      var tabela = document.getElementById('tabelaMovimentacoes');
      if (tabela) {
        tabela.addEventListener('click', function(e) {
          var button = e.target.closest('[data-action]');
          if (!button) return;
          
          var id = button.dataset.id;
          var action = button.dataset.action;
          
          if (action === 'view') viewMovimentacao(id);
          else if (action === 'edit') editMovimentacao(id);
          else if (action === 'delete') deleteMovimentacao(id);
        });
      }
      
      // Fechar modais ao clicar fora
      document.querySelectorAll('#modalForm, #modalView').forEach(function(modal) {
        modal.addEventListener('click', function(e) {
          if (e.target === this) closeModal(this.id);
        });
      });
    });

    // Filtros
    function applyFilters() {
      var tipo = document.getElementById('filtroTipo').value;
      var produto = document.getElementById('filtroProduto').value;
      var dataInicial = document.getElementById('filtroDataInicial').value;
      var dataFinal = document.getElementById('filtroDataFinal').value;
      
      var params = new URLSearchParams();
      if (tipo) params.append('tipo', tipo);
      if (produto) params.append('produto_id', produto);
      if (dataInicial) params.append('data_inicial', dataInicial);
      if (dataFinal) params.append('data_fim', dataFinal);
      
      window.location.href = '/movimentacoes?' + params.toString();
    }

    function clearFilters() {
      window.location.href = '/movimentacoes';
    }

    // Modal controls
    function openModal(modalId) {
      var modal = document.getElementById(modalId);
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      lucide.createIcons();
    }
    
    function closeModal(modalId) {
      var modal = document.getElementById(modalId);
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }

    function openCreateModal() {
      document.getElementById('modalTitle').textContent = 'Nova Movimentação';
      document.getElementById('movimentacaoForm').action = '/movimentacoes';
      document.getElementById('movimentacaoForm').reset();
      document.getElementById('valor_total_display').value = '';
      document.getElementById('fornecedor_group').style.display = 'none';
      document.getElementById('cliente_group').style.display = 'none';
      openModal('modalForm');
    }

    function updateFormFields() {
      var tipo = document.getElementById('tipo').value;
      var fornecedorGroup = document.getElementById('fornecedor_group');
      var clienteGroup = document.getElementById('cliente_group');
      
      if (tipo === 'ENTRADA') {
        fornecedorGroup.style.display = 'block';
        clienteGroup.style.display = 'none';
      } else if (tipo === 'SAIDA') {
        fornecedorGroup.style.display = 'none';
        clienteGroup.style.display = 'block';
      } else {
        fornecedorGroup.style.display = 'none';
        clienteGroup.style.display = 'none';
      }
    }

    function calcularValorTotal() {
      var quantidade = parseFloat(document.getElementById('quantidade').value) || 0;
      var precoUnitario = parseFloat(document.getElementById('preco_unitario').value) || 0;
      var valorTotal = quantidade * precoUnitario;
      
      document.getElementById('valor_total_display').value = 'R$ ' + valorTotal.toFixed(2);
      document.getElementById('valor_total').value = valorTotal.toFixed(2);
    }

    // View movimentação
    async function viewMovimentacao(id) {
      try {
        var response = await fetch('/movimentacoes/' + id);
        var data = await response.json();
        
        var html = '<div class="grid grid-cols-2 gap-4">' +
          '<div class="form-group"><label class="text-xs font-semibold text-secondary-500 uppercase">Data</label><p class="font-medium">' + new Date(data.created_at).toLocaleDateString('pt-BR') + '</p></div>' +
          '<div class="form-group"><label class="text-xs font-semibold text-secondary-500 uppercase">Tipo</label><p><span class="badge ' + (data.tipo === 'ENTRADA' ? 'badge-success' : 'badge-warning') + '">' + data.tipo + '</span></p></div>' +
          '<div class="form-group col-span-2"><label class="text-xs font-semibold text-secondary-500 uppercase">Produto</label><p class="font-medium">' + data.produto_codigo + ' - ' + data.produto_descricao + '</p></div>' +
          '<div class="form-group"><label class="text-xs font-semibold text-secondary-500 uppercase">Quantidade</label><p class="font-medium">' + (parseFloat(data.quantidade) % 1 === 0 ? parseFloat(data.quantidade) : parseFloat(data.quantidade).toFixed(1)) + '</p></div>' +
          '<div class="form-group"><label class="text-xs font-semibold text-secondary-500 uppercase">Preço Unitário</label><p class="font-medium">' + (data.preco_unitario ? 'R$ ' + parseFloat(data.preco_unitario).toFixed(2) : '-') + '</p></div>' +
          '<div class="form-group"><label class="text-xs font-semibold text-secondary-500 uppercase">Valor Total</label><p class="font-semibold text-green-600 text-lg">R$ ' + parseFloat(data.valor_total_calc || 0).toFixed(2) + '</p></div>' +
          '<div class="form-group"><label class="text-xs font-semibold text-secondary-500 uppercase">' + (data.tipo === 'ENTRADA' ? 'Fornecedor' : 'Cliente') + '</label><p class="font-medium">' + (data.fornecedor_nome || data.cliente_nome || '-') + '</p></div>' +
          '<div class="form-group"><label class="text-xs font-semibold text-secondary-500 uppercase">RCA</label><p class="font-medium">' + (data.rca || '-') + '</p></div>' +
          '<div class="form-group"><label class="text-xs font-semibold text-secondary-500 uppercase">Documento</label><p class="font-medium">' + (data.documento || '-') + '</p></div>' +
          (data.observacao ? '<div class="form-group col-span-2"><label class="text-xs font-semibold text-secondary-500 uppercase">Observações</label><p class="font-medium">' + data.observacao + '</p></div>' : '') +
          '</div>';
        
        document.getElementById('viewContent').innerHTML = html;
        openModal('modalView');
      } catch (error) {
        alert('Erro ao carregar movimentação');
        console.error(error);
      }
    }

    // Edit movimentação
    async function editMovimentacao(id) {
      try {
        var response = await fetch('/movimentacoes/' + id);
        var data = await response.json();
        
        document.getElementById('modalTitle').textContent = 'Editar Movimentação';
        document.getElementById('movimentacaoForm').action = '/movimentacoes/' + id + '/edit';
        
        document.getElementById('tipo').value = data.tipo;
        document.getElementById('produto_id').value = data.produto_id;
        document.getElementById('quantidade').value = data.quantidade;
        document.getElementById('preco_unitario').value = data.preco_unitario || '';
        document.getElementById('fornecedor_id').value = data.fornecedor_id || '';
        document.getElementById('cliente_nome').value = data.cliente_nome || '';
        document.getElementById('rca').value = data.rca || '';
        document.getElementById('documento').value = data.documento || '';
        document.getElementById('observacao').value = data.observacao || '';
        
        updateFormFields();
        calcularValorTotal();
        
        openModal('modalForm');
      } catch (error) {
        alert('Erro ao carregar movimentação');
        console.error(error);
      }
    }

    // Delete movimentação COM CSRF
    function deleteMovimentacao(id) {
      if (confirm('Tem certeza que deseja excluir esta movimentação?')) {
        var form = document.getElementById('deleteForm');
        form.action = '/movimentacoes/delete/' + id;
        form.submit();
      }
    }
  </script>
