<!-- views/entregas.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Entregas | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'entregas' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container">
      
      <!-- Page Header -->
      <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-secondary-900">Sistema de Entregas</h1>
            <p class="mt-1 text-secondary-500">Gerencie suas entregas e otimize rotas</p>
          </div>
          <div class="flex items-center gap-2">
            <input type="date" id="filtroData" value="<%= dataFiltro %>" class="form-input" onchange="filtrarPorData()">
          </div>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Total Entregas -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-primary-500">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center">
              <i data-lucide="package" class="w-5 h-5 text-primary-600"></i>
            </div>
            <div>
              <p class="text-2xl font-bold text-secondary-900"><%= stats.total_entregas %></p>
              <p class="text-sm text-secondary-500">Total de Entregas</p>
            </div>
          </div>
        </div>

        <!-- Entregues -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-green-500">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center">
              <i data-lucide="check-circle" class="w-5 h-5 text-green-600"></i>
            </div>
            <div>
              <p class="text-2xl font-bold text-green-600"><%= stats.entregues %></p>
              <p class="text-sm text-secondary-500">Entregues</p>
            </div>
          </div>
        </div>

        <!-- Pendentes -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-yellow-500">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-yellow-100 flex items-center justify-center">
              <i data-lucide="clock" class="w-5 h-5 text-yellow-600"></i>
            </div>
            <div>
              <p class="text-2xl font-bold text-yellow-600"><%= stats.pendentes %></p>
              <p class="text-sm text-secondary-500">Pendentes</p>
            </div>
          </div>
        </div>

        <!-- Valor Total -->
        <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-blue-500">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
              <i data-lucide="banknote" class="w-5 h-5 text-blue-600"></i>
            </div>
            <div>
              <p class="text-2xl font-bold text-blue-600">R$ <%= stats.valor_total.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></p>
              <p class="text-sm text-secondary-500">Valor Total</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Informações de Tempo Estimado -->
      <% if (stats.pendentes > 0) { %>
      <div class="bg-secondary-100 border border-secondary-200 rounded-xl p-5 mb-6">
        <h3 class="text-base font-semibold text-secondary-900 flex items-center gap-2 mb-4">
          <i data-lucide="timer" class="w-5 h-5 text-secondary-600"></i>
          Estimativa de Tempo
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="flex justify-between items-center bg-white rounded-lg p-3">
            <span class="text-sm text-secondary-600">Tempo Total:</span>
            <span class="font-semibold text-green-600"><%= stats.tempo_total_estimado_horas %>h (<%= stats.tempo_total_estimado_minutos %> min)</span>
          </div>
          <div class="flex justify-between items-center bg-white rounded-lg p-3">
            <span class="text-sm text-secondary-600">Conclusão:</span>
            <span class="font-semibold text-green-600"><%= stats.horario_conclusao_estimado || 'N/A' %></span>
          </div>
          <div class="flex justify-between items-center bg-white rounded-lg p-3">
            <span class="text-sm text-secondary-600">Por Entrega:</span>
            <span class="font-semibold text-green-600"><%= stats.tempo_por_entrega %> min</span>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Controles Principais -->
      <div class="flex flex-wrap gap-3 mb-6">
        <a href="/entregas/config" class="btn btn-secondary">
          <i data-lucide="settings" class="w-4 h-4 mr-2"></i>
          Configurar Armazém
        </a>
        
        <% if (stats.pendentes > 0) { %>
        <button type="button" onclick="otimizarRota()" class="btn btn-primary">
          <i data-lucide="map" class="w-4 h-4 mr-2"></i>
          Otimizar Rota
        </button>
        <% } %>
        
        <button type="button" onclick="mostrarFormulario()" class="btn btn-success">
          <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
          Nova Entrega
        </button>
      </div>

      <!-- Formulário Nova Entrega -->
      <div id="formularioEntrega" class="card mb-6 hidden">
        <div class="card-header flex items-center justify-between">
          <h2 class="text-lg font-semibold text-secondary-900 flex items-center gap-2">
            <i data-lucide="package-plus" class="w-5 h-5 text-primary-600"></i>
            Nova Entrega
          </h2>
          <button type="button" onclick="esconderFormulario()" class="text-secondary-400 hover:text-secondary-600">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>
        <div class="card-body">
          <form action="/entregas" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              <!-- Data Entrega -->
              <div class="form-group">
                <label for="data_entrega" class="form-label">Data da Entrega *</label>
                <input type="date" id="data_entrega" name="data_entrega" class="form-input" value="<%= dataFiltro %>" required>
              </div>
              
              <!-- Cliente Select -->
              <div class="form-group">
                <label for="cliente_id" class="form-label">Cliente (opcional)</label>
                <select id="cliente_id" name="cliente_id" class="form-select">
                  <option value="">Selecione um cliente...</option>
                  <% if (clientes && clientes.length > 0) { %>
                    <% clientes.forEach(function(cliente) { %>
                      <option value="<%= cliente.id %>" data-endereco="<%= cliente.endereco || '' %>"><%= cliente.nome %></option>
                    <% }); %>
                  <% } %>
                </select>
              </div>
              
              <!-- Valor -->
              <div class="form-group">
                <label for="valor_entrega" class="form-label">Valor da Entrega</label>
                <input type="number" id="valor_entrega" name="valor_entrega" class="form-input" min="0" step="0.01" placeholder="0,00">
              </div>
              
              <!-- Nome Cliente -->
              <div class="form-group md:col-span-2">
                <label for="cliente_nome" class="form-label">Nome do Cliente *</label>
                <input type="text" id="cliente_nome" name="cliente_nome" class="form-input" placeholder="Nome completo" required>
              </div>
              
              <!-- Endereço -->
              <div class="form-group lg:col-span-3">
                <label for="endereco_completo" class="form-label">Endereço Completo *</label>
                <textarea id="endereco_completo" name="endereco_completo" class="form-input" rows="2" placeholder="Rua, número, bairro, cidade..." required></textarea>
              </div>
              
              <!-- Observações -->
              <div class="form-group lg:col-span-3">
                <label for="observacoes" class="form-label">Observações</label>
                <textarea id="observacoes" name="observacoes" class="form-input" rows="2" placeholder="Informações adicionais..."></textarea>
              </div>
            </div>
            
            <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-secondary-200">
              <button type="button" onclick="esconderFormulario()" class="btn btn-secondary">Cancelar</button>
              <button type="submit" class="btn btn-success">
                <i data-lucide="save" class="w-4 h-4 mr-2"></i>
                Salvar Entrega
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Lista de Entregas -->
      <div class="card">
        <div class="card-header flex items-center justify-between">
          <h2 class="text-lg font-semibold text-secondary-900 flex items-center gap-2">
            <i data-lucide="clipboard-list" class="w-5 h-5 text-primary-600"></i>
            Entregas de <%= dataFiltro %>
          </h2>
          <span class="text-sm text-secondary-500"><%= entregas ? entregas.length : 0 %> entregas</span>
        </div>
        
        <% if (entregas && entregas.length > 0) { %>
          <div class="table-container">
            <table class="table">
              <thead>
                <tr>
                  <th class="text-center w-16">Ordem</th>
                  <th>Cliente</th>
                  <th>Endereço</th>
                  <th class="text-right">Valor</th>
                  <th class="text-center">Status</th>
                  <th>Observações</th>
                  <th class="text-right">Ações</th>
                </tr>
              </thead>
              <tbody>
                <% entregas.forEach(function(entrega) { %>
                  <tr class="<%= entrega.status === 'ENTREGUE' ? 'bg-green-50' : '' %>">
                    <td class="text-center">
                      <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-primary-100 text-primary-700 text-sm font-bold">
                        <%= entrega.ordem_entrega || '-' %>
                      </span>
                    </td>
                    <td>
                      <p class="font-medium text-secondary-900"><%= entrega.cliente_nome %></p>
                    </td>
                    <td class="text-secondary-600 text-sm max-w-xs truncate" title="<%= entrega.endereco_completo %>">
                      <%= entrega.endereco_completo %>
                    </td>
                    <td class="text-right font-medium">
                      R$ <%= parseFloat(entrega.valor_entrega || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
                    </td>
                    <td class="text-center">
                      <% if (entrega.status === 'ENTREGUE') { %>
                        <span class="badge badge-success">
                          <i data-lucide="check" class="w-3 h-3 mr-1"></i>
                          Entregue
                        </span>
                        <% if (entrega.hora_entrega) { %>
                          <p class="text-xs text-secondary-500 mt-1"><%= new Date(entrega.hora_entrega).toLocaleTimeString('pt-BR') %></p>
                        <% } %>
                      <% } else { %>
                        <span class="badge badge-warning">
                          <i data-lucide="clock" class="w-3 h-3 mr-1"></i>
                          Pendente
                        </span>
                      <% } %>
                    </td>
                    <td class="text-secondary-500 text-sm max-w-xs truncate" title="<%= entrega.observacoes || '' %>">
                      <%= entrega.observacoes || '-' %>
                    </td>
                    <td class="text-right">
                      <div class="flex justify-end gap-2">
                        <% if (entrega.status !== 'ENTREGUE') { %>
                          <form action="/entregas/marcar-entregue/<%= entrega.id %>" method="POST" class="inline" data-action="entregar" onsubmit="return confirm('Marcar como entregue?');">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="text-sm text-green-600 hover:text-green-700 flex items-center gap-1">
                              <i data-lucide="check-circle" class="w-4 h-4"></i>
                              Entregar
                            </button>
                          </form>
                        <% } %>
                        
                        <form action="/entregas/delete/<%= entrega.id %>" method="POST" class="inline" data-action="excluir" onsubmit="return confirm('Excluir esta entrega?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="text-sm text-danger-600 hover:text-danger-700 flex items-center gap-1">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                            Excluir
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="card-body py-12 text-center">
            <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mx-auto mb-4">
              <i data-lucide="package-x" class="w-8 h-8 text-secondary-400"></i>
            </div>
            <h3 class="text-lg font-medium text-secondary-900 mb-2">Nenhuma entrega programada</h3>
            <p class="text-secondary-500 mb-6">Não há entregas para esta data.</p>
            <button type="button" onclick="mostrarFormulario()" class="btn btn-primary">
              <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
              Adicionar Entrega
            </button>
          </div>
        <% } %>
      </div>

    </main>
  </div>

  <script>
    // Inicializa ícones
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
    });
    
    // CSRF Token para requisições fetch
    var csrfToken = '<%= csrfToken %>';
    var dataFiltro = '<%= dataFiltro %>';
    
    // Mostrar/esconder formulário
    function mostrarFormulario() {
      document.getElementById('formularioEntrega').classList.remove('hidden');
      lucide.createIcons();
    }
    
    function esconderFormulario() {
      document.getElementById('formularioEntrega').classList.add('hidden');
    }
    
    // Filtrar por data
    function filtrarPorData() {
      var data = document.getElementById('filtroData').value;
      window.location.href = '/entregas?data=' + data;
    }
    
    // Preencher dados quando selecionar cliente
    document.getElementById('cliente_id').addEventListener('change', function() {
      var select = this;
      var option = select.options[select.selectedIndex];
      
      if (option.value) {
        document.getElementById('cliente_nome').value = option.text;
        document.getElementById('endereco_completo').value = option.dataset.endereco || '';
      } else {
        document.getElementById('cliente_nome').value = '';
        document.getElementById('endereco_completo').value = '';
      }
    });
    
    // Otimizar rota
    async function otimizarRota() {
      try {
        var response = await fetch('/entregas/otimizar-rota', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken
          },
          body: JSON.stringify({ data_entrega: dataFiltro })
        });
        
        var result = await response.json();
        
        if (result.success) {
          alert('Rota otimizada com sucesso!\n\nEstatísticas:\n- ' + result.estatisticas.total_entregas + ' entregas\n- ' + result.estatisticas.tempo_total_horas + 'h estimadas');
          location.reload();
        } else {
          alert('Erro: ' + result.message);
        }
      } catch (error) {
        alert('Erro ao otimizar rota');
        console.error(error);
      }
    }
  </script>
</body>
</html>
