<!-- views/dashboard.ejs -->
<!-- Dashboard redesenhado com Tailwind -->

<%- include('partials/sidebar', { currentPage: 'dashboard' }) %>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    lucide.createIcons();
  });
</script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'dashboard' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container">
      <!-- Page Header -->
      <%- include('partials/page-header', { 
        title: 'Dashboard', 
        subtitle: 'Visão geral do seu negócio',
        actions: `
          <form method="GET" class="flex items-center gap-2">
            <input type="date" name="dataInicial" value="${filtros.dataInicial}" class="form-input py-2">
            <span class="text-secondary-400">até</span>
            <input type="date" name="dataFinal" value="${filtros.dataFinal}" class="form-input py-2">
            <button type="submit" class="btn btn-primary">
              <i data-lucide="filter" class="w-4 h-4 mr-2"></i>
              Filtrar
            </button>
          </form>
        `
      }) %>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <%- include('partials/stat-card', {
          title: 'Faturamento',
          value: dashboardData.faturamento.atual.toLocaleString('pt-BR', { minimumFractionDigits: 2 }),
          prefix: 'R$',
          icon: 'dollar-sign',
          iconColor: 'primary',
          change: dashboardData.faturamento.variacao,
          changeLabel: 'vs mês anterior'
        }) %>

        <%- include('partials/stat-card', {
          title: 'Lucro',
          value: dashboardData.lucro.valor.toLocaleString('pt-BR', { minimumFractionDigits: 2 }),
          prefix: 'R$',
          icon: 'trending-up',
          iconColor: dashboardData.lucro.valor >= 0 ? 'green' : 'red',
          change: parseFloat(dashboardData.lucro.margem),
          changeLabel: 'margem'
        }) %>

        <%- include('partials/stat-card', {
          title: 'Vendas',
          value: dashboardData.faturamento.totalVendas,
          icon: 'shopping-cart',
          iconColor: 'blue'
        }) %>

        <%- include('partials/stat-card', {
          title: 'Saldo Caixa',
          value: dashboardData.fluxoCaixa.saldo.toLocaleString('pt-BR', { minimumFractionDigits: 2 }),
          prefix: 'R$',
          icon: 'wallet',
          iconColor: dashboardData.fluxoCaixa.saldo >= 0 ? 'green' : 'red'
        }) %>
      </div>

      <!-- Alerts Row -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <!-- Contas Vencidas -->
        <% if (dashboardData.contasVencidas.total > 0) { %>
          <div class="card border-l-4 border-l-danger-500">
            <div class="card-body flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-danger-100 flex items-center justify-center">
                <i data-lucide="alert-circle" class="w-6 h-6 text-danger-600"></i>
              </div>
              <div>
                <p class="text-sm font-medium text-secondary-900">Contas Vencidas</p>
                <p class="text-2xl font-bold text-danger-600"><%= dashboardData.contasVencidas.total %></p>
                <p class="text-xs text-secondary-500">
                  R$ <%= parseFloat(dashboardData.contasVencidas.valor_total).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                </p>
              </div>
              <a href="/contas-a-pagar" class="ml-auto btn btn-sm btn-danger">Ver</a>
            </div>
          </div>
        <% } %>

        <!-- Inadimplência -->
        <% if (dashboardData.inadimplencia.clientes_inadimplentes > 0) { %>
          <div class="card border-l-4 border-l-warning-500">
            <div class="card-body flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-warning-100 flex items-center justify-center">
                <i data-lucide="users" class="w-6 h-6 text-warning-600"></i>
              </div>
              <div>
                <p class="text-sm font-medium text-secondary-900">Inadimplência</p>
                <p class="text-2xl font-bold text-warning-600"><%= dashboardData.inadimplencia.clientes_inadimplentes %></p>
                <p class="text-xs text-secondary-500">
                  R$ <%= parseFloat(dashboardData.inadimplencia.valor_total).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                </p>
              </div>
              <a href="/inadimplencia" class="ml-auto btn btn-sm btn-warning">Ver</a>
            </div>
          </div>
        <% } %>

        <!-- Entregas Pendentes -->
        <% if (dashboardData.entregas && dashboardData.entregas.pendentes > 0) { %>
          <div class="card border-l-4 border-l-primary-500">
            <div class="card-body flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center">
                <i data-lucide="truck" class="w-6 h-6 text-primary-600"></i>
              </div>
              <div>
                <p class="text-sm font-medium text-secondary-900">Entregas Pendentes</p>
                <p class="text-2xl font-bold text-primary-600"><%= dashboardData.entregas.pendentes %></p>
                <p class="text-xs text-secondary-500">
                  de <%= dashboardData.entregas.total %> total
                </p>
              </div>
              <a href="/entregas" class="ml-auto btn btn-sm btn-primary">Ver</a>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Two Column Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Top Produtos -->
        <div class="card">
          <div class="card-header flex items-center justify-between">
            <h2 class="text-lg font-semibold text-secondary-900">Top Produtos</h2>
            <a href="/produtos" class="text-sm text-primary-600 hover:text-primary-700">Ver todos</a>
          </div>
          <div class="card-body p-0">
            <% if (dashboardData.topProdutos && dashboardData.topProdutos.length > 0) { %>
              <div class="divide-y divide-secondary-100">
                <% dashboardData.topProdutos.forEach((produto, index) => { %>
                  <div class="flex items-center gap-4 px-6 py-4">
                    <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-sm font-medium text-primary-700">
                      <%= index + 1 %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-secondary-900 truncate"><%= produto.descricao %></p>
                      <p class="text-xs text-secondary-500"><%= produto.quantidade_vendida %> vendidos</p>
                    </div>
                    <div class="text-right">
                      <p class="text-sm font-semibold text-secondary-900">
                        R$ <%= parseFloat(produto.valor_total).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                      </p>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="p-6 text-center text-secondary-500">
                Nenhuma venda no período
              </div>
            <% } %>
          </div>
        </div>

        <!-- Produtos com Baixo Estoque -->
        <div class="card">
          <div class="card-header flex items-center justify-between">
            <h2 class="text-lg font-semibold text-secondary-900">Estoque Baixo</h2>
            <a href="/produtos" class="text-sm text-primary-600 hover:text-primary-700">Ver todos</a>
          </div>
          <div class="card-body p-0">
            <% if (dashboardData.produtosBaixoEstoque && dashboardData.produtosBaixoEstoque.length > 0) { %>
              <div class="divide-y divide-secondary-100">
                <% dashboardData.produtosBaixoEstoque.forEach(produto => { %>
                  <div class="flex items-center gap-4 px-6 py-4">
                    <div class="w-8 h-8 rounded-full bg-danger-100 flex items-center justify-center">
                      <i data-lucide="alert-triangle" class="w-4 h-4 text-danger-600"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-secondary-900 truncate"><%= produto.descricao %></p>
                      <p class="text-xs text-secondary-500"><%= produto.codigo %></p>
                    </div>
                    <div class="text-right">
                      <span class="badge badge-danger">
                        <%= produto.saldo_atual %> / <%= produto.estoque_minimo %>
                      </span>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="p-6 text-center">
                <div class="w-12 h-12 rounded-full bg-success-100 flex items-center justify-center mx-auto mb-3">
                  <i data-lucide="check" class="w-6 h-6 text-success-600"></i>
                </div>
                <p class="text-secondary-500">Todos os produtos com estoque adequado</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Fluxo de Caixa Resumo -->
      <div class="mt-6">
        <div class="card">
          <div class="card-header flex items-center justify-between">
            <h2 class="text-lg font-semibold text-secondary-900">Resumo Financeiro</h2>
            <a href="/fluxo-caixa" class="text-sm text-primary-600 hover:text-primary-700">Ver detalhes</a>
          </div>
          <div class="card-body">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="text-center p-4 rounded-lg bg-green-50">
                <p class="text-sm text-green-600 font-medium mb-1">Entradas</p>
                <p class="text-2xl font-bold text-green-700">
                  R$ <%= dashboardData.fluxoCaixa.creditos.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                </p>
              </div>
              <div class="text-center p-4 rounded-lg bg-red-50">
                <p class="text-sm text-red-600 font-medium mb-1">Saídas</p>
                <p class="text-2xl font-bold text-red-700">
                  R$ <%= dashboardData.fluxoCaixa.debitos.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                </p>
              </div>
              <div class="text-center p-4 rounded-lg <%= dashboardData.fluxoCaixa.saldo >= 0 ? 'bg-blue-50' : 'bg-orange-50' %>">
                <p class="text-sm <%= dashboardData.fluxoCaixa.saldo >= 0 ? 'text-blue-600' : 'text-orange-600' %> font-medium mb-1">Saldo</p>
                <p class="text-2xl font-bold <%= dashboardData.fluxoCaixa.saldo >= 0 ? 'text-blue-700' : 'text-orange-700' %>">
                  R$ <%= dashboardData.fluxoCaixa.saldo.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>

  <script>
    lucide.createIcons();
  </script>
</body>
</html>
