<!-- views/rcas.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RCAs | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'rcas' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container">
      
      <!-- Page Header -->
      <div class="mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-secondary-900">RCAs</h1>
            <p class="mt-1 text-secondary-500">Cadastro de Representantes Comerciais</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-secondary-500"><%= rcas.length %> RCAs cadastrados</span>
            <button type="button" onclick="document.getElementById('formCadastro').classList.toggle('hidden')" class="btn btn-primary">
              <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
              Novo RCA
            </button>
          </div>
        </div>
      </div>

      <!-- Formulário de Cadastro -->
      <div id="formCadastro" class="card mb-6 hidden">
        <div class="card-header flex items-center justify-between">
          <h2 class="text-lg font-semibold text-secondary-900">Cadastrar Novo RCA</h2>
          <button type="button" onclick="document.getElementById('formCadastro').classList.add('hidden')" class="text-secondary-400 hover:text-secondary-600">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>
        <div class="card-body">
          <form action="/rcas" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <!-- Nome -->
              <div class="form-group">
                <label for="nome" class="form-label">Nome *</label>
                <input type="text" id="nome" name="nome" required class="form-input" placeholder="Nome completo">
              </div>
              
              <!-- CPF -->
              <div class="form-group">
                <label for="cpf" class="form-label">CPF</label>
                <input type="text" id="cpf" name="cpf" class="form-input" placeholder="000.000.000-00" maxlength="14">
              </div>
              
              <!-- Praça -->
              <div class="form-group">
                <label for="praca" class="form-label">Praça (Cidade/Região)</label>
                <input type="text" id="praca" name="praca" class="form-input" placeholder="Ex: Recife e Região">
              </div>
              
              <!-- CEP -->
              <div class="form-group">
                <label for="cep" class="form-label">CEP</label>
                <input type="text" id="cep" name="cep" class="form-input" placeholder="00000-000" maxlength="9">
              </div>
              
              <!-- Endereço -->
              <div class="form-group md:col-span-2">
                <label for="endereco" class="form-label">Endereço</label>
                <input type="text" id="endereco" name="endereco" class="form-input" placeholder="Rua, número, bairro">
              </div>
              
              <!-- Telefone -->
              <div class="form-group">
                <label for="telefone" class="form-label">Telefone</label>
                <input type="text" id="telefone" name="telefone" class="form-input" placeholder="(00) 00000-0000">
              </div>
              
              <!-- Email -->
              <div class="form-group">
                <label for="email" class="form-label">E-mail</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="email@exemplo.com">
              </div>
              
              <!-- Observações -->
              <div class="form-group md:col-span-2">
                <label for="observacao" class="form-label">Observações</label>
                <textarea id="observacao" name="observacao" rows="3" class="form-input" placeholder="Informações adicionais..."></textarea>
              </div>
            </div>
            
            <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-secondary-200">
              <button type="button" onclick="document.getElementById('formCadastro').classList.add('hidden')" class="btn btn-secondary">
                Cancelar
              </button>
              <button type="submit" class="btn btn-primary">
                <i data-lucide="save" class="w-4 h-4 mr-2"></i>
                Cadastrar RCA
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Busca -->
      <div class="card mb-6">
        <div class="card-body py-4">
          <div class="relative max-w-md">
            <input type="text" id="busca" placeholder="Buscar por nome, praça ou CPF..." class="form-input pl-10" onkeyup="filtrarRCAs()">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-secondary-400"></i>
          </div>
        </div>
      </div>

      <!-- Lista de RCAs -->
      <% if (rcas.length === 0) { %>
        <div class="card">
          <div class="card-body py-12 text-center">
            <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mx-auto mb-4">
              <i data-lucide="user-check" class="w-8 h-8 text-secondary-400"></i>
            </div>
            <h3 class="text-lg font-medium text-secondary-900 mb-2">Nenhum RCA cadastrado</h3>
            <p class="text-secondary-500 mb-6">Comece adicionando seu primeiro representante comercial.</p>
            <button type="button" onclick="document.getElementById('formCadastro').classList.remove('hidden')" class="btn btn-primary">
              <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
              Cadastrar RCA
            </button>
          </div>
        </div>
      <% } else { %>
        <div class="card">
          <div class="table-container">
            <table class="table" id="tabelaRCAs">
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>Praça</th>
                  <th>CPF</th>
                  <th>Telefone</th>
                  <th>E-mail</th>
                  <th class="text-right">Ações</th>
                </tr>
              </thead>
              <tbody>
                <% rcas.forEach(rca => { %>
                  <tr class="rca-row" 
                      data-nome="<%= rca.nome.toLowerCase() %>" 
                      data-praca="<%= (rca.praca || '').toLowerCase() %>"
                      data-cpf="<%= (rca.cpf || '').toLowerCase() %>">
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-full bg-primary-100 flex items-center justify-center">
                          <span class="text-sm font-semibold text-primary-700"><%= rca.nome.charAt(0).toUpperCase() %></span>
                        </div>
                        <div>
                          <p class="font-medium text-secondary-900"><%= rca.nome %></p>
                          <% if (rca.endereco) { %>
                            <p class="text-xs text-secondary-500"><%= rca.endereco %></p>
                          <% } %>
                        </div>
                      </div>
                    </td>
                    <td>
                      <% if (rca.praca) { %>
                        <span class="badge badge-primary"><%= rca.praca %></span>
                      <% } else { %>
                        <span class="text-secondary-400">-</span>
                      <% } %>
                    </td>
                    <td class="text-secondary-600 font-mono text-sm"><%= rca.cpf || '-' %></td>
                    <td>
                      <% if (rca.telefone) { %>
                        <a href="tel:<%= rca.telefone %>" class="text-secondary-600 hover:text-primary-600">
                          <%= rca.telefone %>
                        </a>
                      <% } else { %>
                        <span class="text-secondary-400">-</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (rca.email) { %>
                        <a href="mailto:<%= rca.email %>" class="text-secondary-600 hover:text-primary-600">
                          <%= rca.email %>
                        </a>
                      <% } else { %>
                        <span class="text-secondary-400">-</span>
                      <% } %>
                    </td>
                    <td class="text-right">
                      <div class="flex justify-end gap-2">
                        <a href="/comissoes?rca_id=<%= rca.id %>" class="text-sm text-primary-600 hover:text-primary-700 flex items-center gap-1">
                          <i data-lucide="percent" class="w-4 h-4"></i>
                          Comissões
                        </a>
                        <form action="/rcas/delete/<%= rca.id %>" method="POST" class="inline" data-nome="<%= rca.nome %>" onsubmit="return confirm('Excluir RCA ' + this.dataset.nome + '?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="text-sm text-danger-600 hover:text-danger-700 flex items-center gap-1">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                            Excluir
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- Contador -->
        <div class="mt-4 text-center text-sm text-secondary-500">
          Exibindo <span id="totalVisivel"><%= rcas.length %></span> de <%= rcas.length %> RCAs
        </div>
      <% } %>

    </main>
  </div>

  <script>
    // Inicializa ícones
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
    });
    
    // Máscara CPF
    document.getElementById('cpf').addEventListener('input', function(e) {
      var value = e.target.value.replace(/\D/g, '');
      if (value.length > 11) value = value.slice(0, 11);
      if (value.length > 9) {
        value = value.replace(/(\d{3})(\d{3})(\d{3})(\d{1,2})/, '$1.$2.$3-$4');
      } else if (value.length > 6) {
        value = value.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1.$2.$3');
      } else if (value.length > 3) {
        value = value.replace(/(\d{3})(\d{1,3})/, '$1.$2');
      }
      e.target.value = value;
    });
    
    // Máscara CEP
    document.getElementById('cep').addEventListener('input', function(e) {
      var value = e.target.value.replace(/\D/g, '');
      if (value.length > 8) value = value.slice(0, 8);
      if (value.length > 5) {
        value = value.replace(/(\d{5})(\d{1,3})/, '$1-$2');
      }
      e.target.value = value;
    });
    
    // Máscara Telefone
    document.getElementById('telefone').addEventListener('input', function(e) {
      var value = e.target.value.replace(/\D/g, '');
      if (value.length > 11) value = value.slice(0, 11);
      if (value.length > 10) {
        value = value.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
      } else if (value.length > 6) {
        value = value.replace(/(\d{2})(\d{4})(\d{0,4})/, '($1) $2-$3');
      } else if (value.length > 2) {
        value = value.replace(/(\d{2})(\d{0,5})/, '($1) $2');
      }
      e.target.value = value;
    });
    
    // Filtro de RCAs
    function filtrarRCAs() {
      var busca = document.getElementById('busca').value.toLowerCase();
      var linhas = document.querySelectorAll('.rca-row');
      var visiveis = 0;
      
      linhas.forEach(function(linha) {
        var nome = linha.dataset.nome;
        var praca = linha.dataset.praca;
        var cpf = linha.dataset.cpf;
        
        var mostrar = nome.includes(busca) || praca.includes(busca) || cpf.includes(busca);
        linha.style.display = mostrar ? '' : 'none';
        if (mostrar) visiveis++;
      });
      
      document.getElementById('totalVisivel').textContent = visiveis;
    }
  </script>
</body>
</html>
