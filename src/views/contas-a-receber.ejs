<!-- views/contas-a-receber.ejs -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contas a Receber | OF Distribuidora</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-secondary-50">

  <%- include('partials/sidebar', { currentPage: 'contas-a-receber' }) %>

  <div class="main-content">
    <%- include('partials/topbar', { user: user }) %>

    <main class="page-container" style="max-width: 1400px;">
      
      <!-- Page Header -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-bold text-secondary-900 flex items-center gap-3">
            <i data-lucide="file-text" class="w-8 h-8 text-primary-600"></i>
            Contas a Receber
          </h1>
          <p class="mt-1 text-secondary-500">Controle de recebimentos futuros e gestão de créditos</p>
        </div>
        <button type="button" onclick="abrirModalConta()" class="btn btn-primary">
          <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
          Nova Conta
        </button>
      </div>

      <!-- Info Banner -->
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6 flex items-start gap-3">
        <i data-lucide="info" class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5"></i>
        <p class="text-sm text-blue-800">
          <strong>Informação importante:</strong> Esta tela exibe apenas as parcelas ainda não vencidas. 
          Parcelas vencidas e não pagas são gerenciadas na seção 
          <a href="/inadimplencia" class="font-semibold text-primary-600 hover:underline">Inadimplência</a>.
        </p>
      </div>

      <!-- Filtros -->
      <div class="card mb-6">
        <div class="card-header">
          <h2 class="text-base font-semibold text-secondary-900 flex items-center gap-2">
            <i data-lucide="filter" class="w-5 h-5 text-secondary-500"></i>
            Filtros de Período
          </h2>
        </div>
        <div class="card-body py-4">
          <form method="GET" action="/contas-a-receber" class="flex flex-wrap items-end gap-4">
            <div class="min-w-[160px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block flex items-center gap-1">
                <i data-lucide="calendar" class="w-3 h-3"></i>
                Data Inicial
              </label>
              <input type="date" name="data_inicio" class="form-input" value="<%= locals.filtros ? filtros.data_inicio : '' %>">
            </div>
            
            <div class="min-w-[160px]">
              <label class="text-xs font-medium text-secondary-500 mb-1 block flex items-center gap-1">
                <i data-lucide="calendar" class="w-3 h-3"></i>
                Data Final
              </label>
              <input type="date" name="data_fim" class="form-input" value="<%= locals.filtros ? filtros.data_fim : '' %>">
            </div>
            
            <button type="submit" class="btn btn-primary">
              <i data-lucide="search" class="w-4 h-4 mr-1"></i>
              Filtrar
            </button>
          </form>
        </div>
      </div>

      <!-- Tabela -->
      <div class="card">
        <div class="card-header flex items-center justify-between">
          <h2 class="text-lg font-semibold text-secondary-900 flex items-center gap-2">
            <i data-lucide="layout-list" class="w-5 h-5 text-primary-600"></i>
            Contas a Receber Pendentes
          </h2>
          <span class="text-sm text-secondary-500"><%= contas ? contas.length : 0 %> conta(s)</span>
        </div>

        <div class="table-container">
          <table class="table">
            <thead>
              <tr>
                <th>Cliente</th>
                <th>Produto/Serviço</th>
                <th>Vencimento</th>
                <th class="text-center">Parcela</th>
                <th class="text-right">Valor</th>
                <th class="text-center">Status</th>
                <th class="text-right">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (contas && contas.length > 0) { %>
                <% contas.forEach(function(conta) { %>
                  <tr>
                    <td>
                      <span class="font-medium text-secondary-900"><%= conta.cliente_nome %></span>
                    </td>
                    <td class="text-secondary-600">
                      <%= conta.produto_descricao || conta.descricao || '-' %>
                    </td>
                    <td class="font-mono text-sm text-secondary-600">
                      <%= new Date(conta.data_vencimento).toLocaleDateString('pt-BR', { timeZone: 'UTC' }) %>
                    </td>
                    <td class="text-center">
                      <span class="inline-flex items-center font-mono text-sm">
                        <span class="font-semibold text-primary-600"><%= conta.numero_parcela %></span>
                        <span class="text-secondary-400 mx-0.5">/</span>
                        <span class="text-secondary-500"><%= conta.total_parcelas %></span>
                      </span>
                    </td>
                    <td class="text-right">
                      <span class="font-semibold font-mono">
                        R$ <%= parseFloat(conta.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
                      </span>
                    </td>
                    <td class="text-center">
                      <% if (conta.status === 'Pago') { %>
                        <span class="badge badge-success">
                          <i data-lucide="check" class="w-3 h-3 mr-1"></i>
                          Recebido
                        </span>
                      <% } else { %>
                        <span class="badge badge-warning">
                          <i data-lucide="clock" class="w-3 h-3 mr-1"></i>
                          Pendente
                        </span>
                      <% } %>
                    </td>
                    <td class="text-right">
                      <div class="flex justify-end gap-2">
                        <% if (conta.status !== 'Pago') { %>
                          <button type="button"
                                  class="btn btn-sm btn-success btn-receber-conta"
                                  data-id="<%= conta.id %>"
                                  data-cliente="<%= conta.cliente_nome || '' %>"
                                  data-valor="<%= conta.valor %>"
                                  data-parcela="<%= conta.numero_parcela %>"
                                  data-total="<%= conta.total_parcelas %>"
                                  title="Registrar recebimento">
                            <i data-lucide="dollar-sign" class="w-3 h-3 mr-1"></i>
                            Receber
                          </button>

                          <% if (!conta.movimentacao_id) { %>
                            <form action="/contas-a-receber/delete/<%= conta.id %>" method="POST" class="inline" onsubmit="return confirm('Confirma a exclusão desta conta manual?');">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                              <button type="submit" class="btn btn-sm btn-secondary text-danger-600" title="Excluir">
                                <i data-lucide="trash-2" class="w-3 h-3 mr-1"></i>
                                Excluir
                              </button>
                            </form>
                          <% } %>
                        <% } else { %>
                          <span class="text-secondary-400 text-sm">-</span>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="7">
                    <div class="py-12 text-center">
                      <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mx-auto mb-4">
                        <i data-lucide="file-x" class="w-8 h-8 text-secondary-400"></i>
                      </div>
                      <h3 class="text-lg font-medium text-secondary-900 mb-2">Nenhuma conta encontrada</h3>
                      <p class="text-secondary-500">Cadastre sua primeira conta a receber</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
            <tfoot>
              <tr class="bg-secondary-50 font-semibold">
                <td colspan="4" class="text-right">Total do Período:</td>
                <td class="text-right font-mono">
                  R$ <%= (totalValor || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
                </td>
                <td colspan="2"></td>
              </tr>
              <tr class="bg-yellow-50 font-semibold text-yellow-700">
                <td colspan="4" class="text-right">Total Pendente:</td>
                <td class="text-right font-mono">
                  R$ <%= (totalPendente || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %>
                </td>
                <td colspan="2"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>

    </main>
  </div>

  <!-- Modal Nova Conta -->
  <div id="modalNovaConta" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-xl mx-4 max-h-[90vh] overflow-y-auto">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between sticky top-0 bg-white">
        <h2 class="text-lg font-bold text-secondary-900 flex items-center gap-2">
          <i data-lucide="plus-circle" class="w-5 h-5 text-primary-600"></i>
          Nova Conta a Receber
        </h2>
        <button type="button" onclick="fecharModalConta()" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      
      <form action="/contas-a-receber" method="POST" class="p-6">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Cliente -->
          <div class="form-group">
            <label for="cliente_nome" class="form-label">
              <i data-lucide="user" class="w-4 h-4 mr-1"></i>
              Cliente *
            </label>
            <select id="cliente_nome" name="cliente_nome" class="form-select" required>
              <option value="">Selecione um cliente...</option>
              <% clientes.forEach(function(cliente) { %>
                <option value="<%= cliente.nome %>"><%= cliente.nome %></option>
              <% }); %>
            </select>
            <a href="/clientes" target="_blank" class="text-xs text-primary-600 hover:underline mt-1 inline-block">
              Cadastrar novo cliente
            </a>
          </div>
          
          <!-- Valor -->
          <div class="form-group">
            <label for="valor" class="form-label">
              <i data-lucide="dollar-sign" class="w-4 h-4 mr-1"></i>
              Valor (R$) *
            </label>
            <input type="number" id="valor" name="valor" class="form-input" step="0.01" min="0.01" placeholder="0,00" required>
          </div>

          <!-- Data Vencimento -->
          <div class="form-group">
            <label for="data_vencimento" class="form-label">
              <i data-lucide="calendar" class="w-4 h-4 mr-1"></i>
              Data de Vencimento *
            </label>
            <input type="date" id="data_vencimento" name="data_vencimento" class="form-input" required>
          </div>
          
          <!-- Categoria -->
          <div class="form-group">
            <label for="categoria_id" class="form-label">
              <i data-lucide="tag" class="w-4 h-4 mr-1"></i>
              Categoria *
            </label>
            <select id="categoria_id" name="categoria_id" class="form-select" required>
              <option value="">Selecione...</option>
              <% categorias.forEach(function(categoria) { %>
                <option value="<%= categoria.id %>"><%= categoria.nome %></option>
              <% }); %>
            </select>
          </div>

          <!-- Descrição -->
          <div class="form-group md:col-span-2">
            <label for="descricao" class="form-label">
              <i data-lucide="file-text" class="w-4 h-4 mr-1"></i>
              Descrição
            </label>
            <input type="text" id="descricao" name="descricao" class="form-input" placeholder="Descrição opcional...">
          </div>
        </div>
        
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-secondary-200">
          <button type="button" onclick="fecharModalConta()" class="btn btn-secondary">
            Cancelar
          </button>
          <button type="submit" class="btn btn-primary">
            <i data-lucide="save" class="w-4 h-4 mr-2"></i>
            Criar Conta
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Recebimento -->
  <div id="modalRecebimento" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4">
      <div class="px-6 py-4 border-b border-secondary-200 flex items-center justify-between">
        <h2 class="text-lg font-bold text-secondary-900 flex items-center gap-2">
          <i data-lucide="banknote" class="w-5 h-5 text-primary-600"></i>
          Registrar Recebimento
        </h2>
        <button type="button" onclick="fecharModalRecebimento()" class="text-secondary-400 hover:text-secondary-600">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>
      
      <form id="formRecebimento" method="POST" class="p-6">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <!-- Info do Recebimento -->
        <div class="bg-secondary-50 rounded-lg p-4 mb-6 space-y-3">
          <div class="flex justify-between items-center pb-2 border-b border-secondary-200">
            <span class="text-sm text-secondary-500">Cliente:</span>
            <span class="font-medium text-secondary-900" id="receber-cliente">-</span>
          </div>
          <div class="flex justify-between items-center pb-2 border-b border-secondary-200">
            <span class="text-sm text-secondary-500">Parcela:</span>
            <span class="font-medium text-secondary-900" id="receber-parcela">-</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-sm text-secondary-500">Valor:</span>
            <span class="text-xl font-bold text-green-600" id="receber-valor">R$ 0,00</span>
          </div>
        </div>

        <!-- Data Recebimento -->
        <div class="form-group">
          <label for="data_recebimento" class="form-label">
            <i data-lucide="calendar" class="w-4 h-4 mr-1"></i>
            Data do Recebimento *
          </label>
          <input type="date" id="data_recebimento" name="data_recebimento" class="form-input" required max="<%= new Date().toISOString().split('T')[0] %>" value="<%= new Date().toISOString().split('T')[0] %>">
          <p class="text-xs text-secondary-500 mt-1">Informe a data em que o pagamento foi recebido</p>
        </div>
        
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-secondary-200">
          <button type="button" onclick="fecharModalRecebimento()" class="btn btn-secondary">
            Cancelar
          </button>
          <button type="submit" class="btn btn-success">
            <i data-lucide="check" class="w-4 h-4 mr-2"></i>
            Confirmar Recebimento
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Inicializa ícones
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();
      
      // Event delegation para botões de receber
      document.addEventListener('click', function(e) {
        var btnReceber = e.target.closest('.btn-receber-conta');
        if (!btnReceber) return;
        
        var contaId = btnReceber.dataset.id;
        var clienteNome = btnReceber.dataset.cliente;
        var valor = parseFloat(btnReceber.dataset.valor);
        var parcela = parseInt(btnReceber.dataset.parcela);
        var totalParcelas = parseInt(btnReceber.dataset.total);
        
        abrirModalRecebimento(contaId, clienteNome, valor, parcela, totalParcelas);
      });
      
      // Fechar modais ao clicar fora
      document.querySelectorAll('#modalNovaConta, #modalRecebimento').forEach(function(modal) {
        modal.addEventListener('click', function(e) {
          if (e.target === this) {
            if (this.id === 'modalNovaConta') fecharModalConta();
            else fecharModalRecebimento();
          }
        });
      });
      
      // Fechar com ESC
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          fecharModalConta();
          fecharModalRecebimento();
        }
      });
      
      // Data vencimento padrão: 30 dias
      var campoVencimento = document.getElementById('data_vencimento');
      if (campoVencimento && !campoVencimento.value) {
        var hoje = new Date();
        var vencimento = new Date(hoje.getTime() + (30 * 24 * 60 * 60 * 1000));
        campoVencimento.value = vencimento.toISOString().split('T')[0];
      }
      
      // Validação formulário recebimento
      document.getElementById('formRecebimento').addEventListener('submit', function(e) {
        var dataRecebimento = document.getElementById('data_recebimento').value;
        var hoje = new Date().toISOString().split('T')[0];
        
        if (!dataRecebimento) {
          e.preventDefault();
          alert('Por favor, selecione a data do recebimento.');
          return;
        }
        
        if (dataRecebimento > hoje) {
          e.preventDefault();
          alert('A data de recebimento não pode ser futura.');
          return;
        }
      });
      
      // Validação formulário nova conta
      document.querySelector('#modalNovaConta form').addEventListener('submit', function(e) {
        var cliente = document.getElementById('cliente_nome').value;
        var valor = document.getElementById('valor').value;
        var vencimento = document.getElementById('data_vencimento').value;
        var categoria = document.getElementById('categoria_id').value;
        
        if (!cliente || !valor || !vencimento || !categoria) {
          e.preventDefault();
          alert('Por favor, preencha todos os campos obrigatórios.');
        }
      });
    });

    // Modal Nova Conta
    function abrirModalConta() {
      var modal = document.getElementById('modalNovaConta');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      lucide.createIcons();
      
      setTimeout(function() {
        document.getElementById('cliente_nome').focus();
      }, 100);
    }

    function fecharModalConta() {
      var modal = document.getElementById('modalNovaConta');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }

    // Modal Recebimento
    function abrirModalRecebimento(contaId, clienteNome, valor, parcela, totalParcelas) {
      document.getElementById('receber-cliente').textContent = clienteNome || 'Não informado';
      document.getElementById('receber-parcela').textContent = parcela + '/' + totalParcelas;
      document.getElementById('receber-valor').textContent = 'R$ ' + parseFloat(valor).toLocaleString('pt-BR', {minimumFractionDigits: 2});
      
      document.getElementById('formRecebimento').action = '/contas-a-receber/receber/' + contaId;
      
      var hoje = new Date().toISOString().split('T')[0];
      document.getElementById('data_recebimento').value = hoje;
      
      var modal = document.getElementById('modalRecebimento');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      
      lucide.createIcons();
      
      setTimeout(function() {
        document.getElementById('data_recebimento').focus();
      }, 100);
    }

    function fecharModalRecebimento() {
      var modal = document.getElementById('modalRecebimento');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }
  </script>
</body>
</html>
